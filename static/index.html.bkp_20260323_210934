  const totalPontos  = d.total_pontos  || 0
  const metaPeriodo  = d.meta_periodo  || 1760
  const pct = metaPeriodo > 0 ? Math.min(Math.round(totalPontos / metaPeriodo * 100), 999) : (d.meta_percentual || 0)
  const fins = r.finalizadas || 0

  // Label do período
  const periodoLabel = temPeriodo
    ? `${new Date(di+'T12:00').toLocaleDateString('pt-BR',{day:'2-digit',month:'short'})} → ${new Date(df+'T12:00').toLocaleDateString('pt-BR',{day:'2-digit',month:'short'})} · ${r.total||0} OS`
    : `Atualizado às ${new Date().toLocaleTimeString('pt-BR')} · ${r.total||0} OS`
  document.getElementById('db-sub').textContent = periodoLabel

  const subTotal    = temPeriodo ? 'no período' : 'hoje'
  const subCampo    = temPeriodo ? 'no período' : 'em execução'
  const subAgendada = temPeriodo ? 'no período' : 'hoje'
  const subMeta     = `${pct}% da meta${temPeriodo ? ' (período)' : ''}`

  document.getElementById('db-kpis').innerHTML=`
    <div class="kpi" style="--ac:var(--cyan)" onclick="abrirModalListaOSTodas()">
      <div class="kpi-lbl">Total OS</div><div class="kpi-val">${r.total||0}</div>
      <div class="kpi-sub">${subTotal}</div>
    </div>
    <div class="kpi" style="--ac:var(--green)" onclick="abrirModalListaOS('finalizada', document.getElementById('f-data-inicio')?.value||null)">
      <div class="kpi-lbl">Finalizadas</div><div class="kpi-val">${fins}</div>
      <div class="kpi-sub">${subMeta}</div>
      <div class="kpi-badge ${pct>=80?'up':'dn'}">${pct}%</div>
    </div>
    <div class="kpi" style="--ac:var(--amber)" onclick="nav('os-atrasadas','central')">
      <div class="kpi-lbl">Em Campo</div><div class="kpi-val">${r.em_campo||0}</div>
      <div class="kpi-sub">${subCampo}</div>
    </div>
    <div class="kpi" style="--ac:var(--cyan)" onclick="nav('agenda-dia','agenda')">
      <div class="kpi-lbl">Agendadas</div><div class="kpi-val">${r.agendadas||0}</div>
      <div class="kpi-sub">${subAgendada}</div>
    </div>
    <div class="kpi" style="--ac:var(--orange)" onclick="nav('ranking','produtividade')">
      <div class="kpi-lbl">Técnicos</div><div class="kpi-val">${d.tecnicos_ativos||0}</div>
      <div class="kpi-sub">ativos no período</div>
    </div>
  `
}

