<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>HubProdutividade</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#07090c;--s1:#0d1117;--s2:#131920;--s3:#1c2333;--border:#1e2731;
  --text:#c9d4e0;--muted:#46586a;--sub:#2d3d50;
  --cyan:#00d4ff;--green:#00e5a0;--red:#ff4d6a;--amber:#ffb83f;--orange:#ff7849;--purple:#a78bfa;
  --sw:220px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--text);font-family:'Bricolage Grotesque',sans-serif;display:flex}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.02'/%3E%3C/svg%3E");pointer-events:none;z-index:9998}

/* ══ SIDEBAR ══════════════════════════════════════ */
.sb{width:var(--sw);background:var(--s1);border-right:1px solid var(--border);height:100vh;display:flex;flex-direction:column;flex-shrink:0;overflow:hidden}
.sb-top{flex:1;overflow-y:auto;padding:16px 12px 0}
.sb-brand{display:flex;align-items:center;gap:10px;margin-bottom:20px;padding:0 4px}
.sb-logo{width:34px;height:34px;background:linear-gradient(135deg,var(--cyan),#0060ff);border-radius:8px;display:grid;place-items:center;font-size:16px;flex-shrink:0;box-shadow:0 0 14px rgba(0,212,255,.2)}
.sb-title{font-size:13px;font-weight:800;letter-spacing:-.01em;line-height:1.2}
.sb-ver{font-size:9px;color:var(--muted);font-family:'DM Mono',monospace}

/* Menu grupos */
.sb-group{margin-bottom:4px}
.sb-group-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:7px 8px;border-radius:6px;cursor:pointer;
  font-size:11px;font-weight:700;color:var(--muted);
  text-transform:uppercase;letter-spacing:.08em;
  transition:all .15s;user-select:none;
  border:1px solid transparent;
}
.sb-group-header:hover{color:var(--text);background:rgba(255,255,255,.03)}
.sb-group-header.active{color:var(--cyan);background:rgba(0,212,255,.06);border-color:rgba(0,212,255,.12)}
.sb-group-header .ic{font-size:13px;margin-right:6px}
.sb-group-header .arrow{font-size:10px;transition:transform .2s;margin-left:auto}
.sb-group-header.open .arrow{transform:rotate(90deg)}

/* Submenus */
.sb-sub{display:none;padding-left:8px;margin-top:2px}
.sb-sub.open{display:block}
.sb-item{
  display:flex;align-items:center;gap:7px;
  padding:6px 8px;border-radius:6px;
  font-size:12px;font-weight:600;color:var(--muted);
  cursor:pointer;transition:all .15s;
  margin-bottom:1px;border:1px solid transparent;
}
.sb-item:hover{color:var(--text);background:rgba(255,255,255,.04)}
.sb-item.active{color:var(--cyan);background:rgba(0,212,255,.08);border-color:rgba(0,212,255,.12)}
.sb-item .dot{width:5px;height:5px;border-radius:50%;background:var(--border);flex-shrink:0}
.sb-item.active .dot{background:var(--cyan)}

.sb-footer{padding:12px;border-top:1px solid var(--border)}
.sb-user{display:flex;align-items:center;gap:8px}
.sb-av{width:26px;height:26px;border-radius:6px;background:var(--s2);border:1px solid var(--border);display:grid;place-items:center;font-size:11px;flex-shrink:0}
.sb-uname{font-size:11px;font-weight:700;line-height:1.2}
.sb-role{font-size:9px;color:var(--muted)}
.live{display:inline-block;width:5px;height:5px;border-radius:50%;background:var(--green);margin-right:3px;animation:blink 2s infinite}

/* ══ MAIN ══════════════════════════════════════════ */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{
  height:48px;background:var(--s1);border-bottom:1px solid var(--border);
  display:flex;align-items:center;padding:0 20px;gap:10px;flex-shrink:0;
}
.topbar-title{font-size:13px;font-weight:800}
.topbar-path{font-size:9px;color:var(--muted);font-family:'DM Mono',monospace}
.topbar-right{margin-left:auto;display:flex;align-items:center;gap:8px}
.tf-data{background:var(--s2);border:1px solid var(--border);color:var(--text);padding:4px 6px;border-radius:6px;font-size:10px;font-family:inherit}
.tf-btn{background:var(--s2);border:1px solid var(--border);padding:4px 10px;border-radius:6px;font-size:10px;cursor:pointer;transition:all .15s;color:var(--muted);white-space:nowrap}
.tf-btn:hover{border-color:var(--cyan);color:var(--cyan)}
.tf-btn.ativo{border-color:var(--cyan);color:var(--cyan);background:rgba(0,212,255,.1);font-weight:700}
.tf-clear{background:rgba(255,77,106,.12);border:1px solid rgba(255,77,106,.3);color:var(--red);padding:4px 8px;border-radius:6px;font-size:10px;cursor:pointer;white-space:nowrap}
.tf-aplicar{background:rgba(0,212,255,.12);border:1px solid rgba(0,212,255,.3);color:var(--cyan);padding:4px 10px;border-radius:6px;font-size:10px;cursor:pointer;white-space:nowrap;font-weight:700}
.tf-aplicar:hover{background:rgba(0,212,255,.2)}
.btn-filtros{background:var(--s2);border:1px solid var(--border);color:var(--muted);padding:5px 12px;border-radius:6px;font-size:11px;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:5px}
.btn-filtros:hover{border-color:var(--cyan);color:var(--cyan)}
.btn-filtros.ativo{border-color:var(--cyan);color:var(--cyan);background:rgba(0,212,255,.1);font-weight:700}
.fm-overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:3000;display:none;align-items:flex-start;justify-content:flex-end;padding-top:56px;padding-right:16px}
.fm-overlay.active{display:flex}
.fm-box{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:20px;width:520px;max-height:80vh;overflow-y:auto;box-shadow:0 8px 32px rgba(0,0,0,.5)}
.fm-titulo{font-size:14px;font-weight:800;margin-bottom:16px;display:flex;justify-content:space-between;align-items:center}
.fm-section{margin-bottom:16px}
.fm-section-lbl{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px}
.fm-datas{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.fm-data-input{background:var(--s2);border:1px solid var(--border);color:var(--text);padding:7px 10px;border-radius:6px;font-size:12px;font-family:inherit;width:100%;box-sizing:border-box}
.fm-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.fm-filtro-btn{background:var(--s2);border:1px solid var(--border);padding:8px 12px;border-radius:8px;font-size:11px;cursor:pointer;transition:all .15s;color:var(--muted);text-align:left;display:flex;justify-content:space-between;align-items:center}
.fm-filtro-btn:hover{border-color:var(--cyan);color:var(--cyan)}
.fm-filtro-btn.ativo{border-color:var(--cyan);color:var(--cyan);background:rgba(0,212,255,.08);font-weight:700}
.fm-actions{display:flex;gap:8px;margin-top:16px;padding-top:14px;border-top:1px solid var(--border)}
.fm-aplicar{flex:1;background:var(--cyan);color:#000;border:none;padding:9px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer}
.fm-limpar{background:rgba(255,77,106,.15);color:var(--red);border:1px solid rgba(255,77,106,.3);padding:9px 16px;border-radius:8px;font-size:12px;cursor:pointer}
.fm-status{font-size:10px;color:var(--muted);text-align:center;margin-top:8px}
.date-chip{background:var(--s2);border:1px solid var(--border);border-radius:5px;padding:3px 9px;font-size:9px;font-family:'DM Mono',monospace;color:var(--muted)}
.ws-dot{width:8px;height:8px;border-radius:50%;background:var(--muted);transition:background .3s}
.ws-dot.connected{background:var(--green);box-shadow:0 0 6px rgba(0,229,160,.4)}
.btn-sync{background:rgba(0,212,255,.1);border:1px solid rgba(0,212,255,.2);color:var(--cyan);border-radius:5px;padding:4px 12px;font-size:10px;font-weight:700;cursor:pointer;transition:all .2s;font-family:'Bricolage Grotesque',sans-serif}
.btn-sync:hover{background:rgba(0,212,255,.18)}
.btn-tv{background:rgba(167,139,250,.1);border:1px solid rgba(167,139,250,.2);color:var(--purple);border-radius:5px;padding:4px 12px;font-size:10px;font-weight:700;cursor:pointer;transition:all .2s;font-family:'Bricolage Grotesque',sans-serif}
.btn-tv:hover{background:rgba(167,139,250,.18)}

/* Badges de alerta no topbar */
.badge-alert{background:var(--red);color:#fff;border-radius:10px;font-size:9px;font-weight:800;padding:1px 6px;font-family:'DM Mono',monospace;min-width:18px;text-align:center}

.content{flex:1;overflow-y:auto;padding:20px}
.page{display:none;animation:fadeUp .25s ease}
.page.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

/* ══ COMPONENTES COMUNS ═══════════════════════════ */
.pg-hd{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:16px}
.pg-title{font-size:20px;font-weight:800;letter-spacing:-.02em}
.pg-title span{color:var(--cyan)}
.pg-sub{font-size:11px;color:var(--muted);margin-top:2px}

.kpi-grid{display:grid;gap:10px;margin-bottom:16px}
.kpi-grid.c5{grid-template-columns:repeat(5,1fr)}
.kpi-grid.c4{grid-template-columns:repeat(4,1fr)}
.kpi-grid.c3{grid-template-columns:repeat(3,1fr)}
.kpi-grid.c2{grid-template-columns:repeat(2,1fr)}
.kpi{background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:14px;position:relative;overflow:hidden;transition:all .2s;cursor:pointer}
.kpi:hover{transform:translateY(-2px);border-color:rgba(255,255,255,.07)}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--ac,var(--cyan))}
.kpi-lbl{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.12em;font-weight:700;margin-bottom:7px}
.kpi-val{font-size:22px;font-weight:800;font-family:'DM Mono',monospace;color:var(--ac,var(--cyan));line-height:1}
.kpi-sub{font-size:9px;color:var(--muted);margin-top:4px}
.kpi-badge{position:absolute;top:12px;right:10px;font-size:9px;font-family:'DM Mono',monospace;padding:2px 6px;border-radius:4px}
.kpi-badge.up{background:rgba(0,229,160,.12);color:var(--green)}
.kpi-badge.dn{background:rgba(255,77,106,.12);color:var(--red)}

.card-grid{display:grid;gap:12px;margin-bottom:16px}
.card-grid.c2{grid-template-columns:1fr 1fr}
.card-grid.c3{grid-template-columns:1fr 1fr 1fr}
.card{background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:16px}
.card-head{font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin-bottom:14px;display:flex;align-items:center;gap:7px}
.card-head::after{content:'';flex:1;height:1px;background:var(--border)}

.badge{display:inline-block;padding:2px 7px;border-radius:4px;font-size:9px;font-weight:700;font-family:'DM Mono',monospace}
.badge.green{background:rgba(0,229,160,.1);color:var(--green)}
.badge.red{background:rgba(255,77,106,.1);color:var(--red)}
.badge.amber{background:rgba(255,184,63,.1);color:var(--amber)}
.badge.cyan{background:rgba(0,212,255,.08);color:var(--cyan)}
.badge.purple{background:rgba(167,139,250,.1);color:var(--purple)}
.badge.muted{background:var(--border);color:var(--muted)}

.alert-chips{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;min-height:28px}
.alert-chip{padding:4px 10px;border-radius:5px;font-size:10px;font-weight:700;border:1px solid;display:flex;align-items:center;gap:5px;cursor:pointer;transition:opacity .2s}
.alert-chip:hover{opacity:.8}
.alert-chip.red{background:rgba(255,77,106,.07);border-color:rgba(255,77,106,.22);color:var(--red)}
.alert-chip.amber{background:rgba(255,184,63,.07);border-color:rgba(255,184,63,.22);color:var(--amber)}
.alert-chip.green{background:rgba(0,229,160,.07);border-color:rgba(0,229,160,.22);color:var(--green)}

.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse}
thead th{font-size:9px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);padding:0 0 8px;text-align:left;border-bottom:1px solid var(--border);white-space:nowrap}
thead th.r{text-align:right}
tbody td{padding:8px 0;font-size:11px;border-bottom:1px solid rgba(255,255,255,.02);vertical-align:middle}
tbody td.r{text-align:right;font-family:'DM Mono',monospace;font-size:10px}
tbody tr:hover td{background:rgba(255,255,255,.015);cursor:pointer}

.rpos{display:inline-flex;width:20px;height:20px;align-items:center;justify-content:center;border-radius:5px;font-size:9px;font-weight:800;font-family:'DM Mono',monospace;margin-right:6px}
.rpos.p1{background:rgba(255,184,63,.15);color:var(--amber)}
.rpos.p2{background:rgba(0,212,255,.1);color:var(--cyan)}
.rpos.p3{background:rgba(0,229,160,.08);color:var(--green)}
.rpos.pn{background:var(--border);color:var(--muted)}

.bar-bg{background:var(--border);height:3px;border-radius:3px;margin-top:3px}
.bar-fill{height:3px;border-radius:3px;transition:width 1s cubic-bezier(.4,0,.2,1)}

.loading{display:flex;align-items:center;justify-content:center;padding:32px;color:var(--muted);font-size:11px;font-family:'DM Mono',monospace}
.spinner{width:14px;height:14px;border:2px solid var(--border);border-top-color:var(--cyan);border-radius:50%;animation:spin .7s linear infinite;margin-right:8px;flex-shrink:0}
.empty{text-align:center;padding:28px;color:var(--muted);font-size:11px}
.empty-icon{font-size:24px;margin-bottom:6px}

/* Lista de OS clicável */
.os-row{display:flex;align-items:center;padding:9px 12px;border-radius:8px;background:var(--s2);border:1px solid var(--border);margin-bottom:6px;cursor:pointer;transition:all .2s}
.os-row:hover{border-color:rgba(0,212,255,.25);transform:translateX(2px)}
.os-id{font-family:'DM Mono',monospace;font-size:11px;font-weight:700;color:var(--cyan);margin-right:10px;flex-shrink:0}
.os-info{flex:1;min-width:0}
.os-assunto{font-size:11px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.os-meta{font-size:10px;color:var(--muted);display:flex;gap:10px;margin-top:2px}
.os-status-chip{font-size:9px;padding:2px 7px;border-radius:4px;font-weight:700;text-transform:uppercase;font-family:'DM Mono',monospace;flex-shrink:0;margin-left:8px}
.os-status-chip.finalizada{background:rgba(0,229,160,.12);color:var(--green)}
.det-kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
.ag-alert{padding:12px 16px;border-radius:8px;font-size:12px;font-weight:700;margin-top:12px}
.ev-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px}
.filtros-bar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;padding:12px 16px;background:var(--s1);border:1px solid var(--border);border-radius:10px;align-items:center}
.filtro-btn{background:var(--s2);border:1px solid var(--border);padding:5px 12px;border-radius:6px;font-size:11px;cursor:pointer;transition:all .2s;color:var(--muted);white-space:nowrap}
.filtro-btn:hover{border-color:var(--cyan);color:var(--cyan)}
.filtro-btn.ativo{border-color:var(--cyan);color:var(--cyan);background:rgba(0,212,255,.1)}
.filtro-data{background:var(--s2);border:1px solid var(--border);color:var(--text);padding:5px 8px;border-radius:6px;font-size:11px;font-family:inherit}
.filtros-bar .sep{width:1px;height:20px;background:var(--border);flex-shrink:0}
.filtro-clear{background:rgba(255,77,106,.15);border:1px solid var(--red);color:var(--red);padding:5px 12px;border-radius:6px;font-size:11px;cursor:pointer;white-space:nowrap}
/* Modal de filtro */
.filtro-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:3000;display:none;align-items:center;justify-content:center}
.filtro-modal-overlay.active{display:flex}
.filtro-modal-box{background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:16px;width:340px;max-height:480px;display:flex;flex-direction:column}
.filtro-modal-title{font-size:13px;font-weight:700;margin-bottom:10px}
.filtro-search{background:var(--s2);border:1px solid var(--border);color:var(--text);padding:7px 10px;border-radius:6px;font-size:11px;width:100%;margin-bottom:8px;box-sizing:border-box}
.filtro-lista{flex:1;overflow-y:auto;max-height:280px;margin-bottom:10px}
.filtro-item{display:flex;align-items:center;gap:8px;padding:7px 4px;cursor:pointer;border-radius:4px;font-size:12px}
.filtro-item:hover{background:rgba(255,255,255,.04)}
.filtro-item input{accent-color:var(--cyan)}
.filtro-modal-actions{display:flex;gap:8px;justify-content:flex-end}
.filtro-modal-actions button{padding:6px 14px;border-radius:6px;font-size:11px;cursor:pointer;border:none}
.fm-ok{background:var(--cyan);color:#000;font-weight:700}
.fm-clear{background:rgba(255,77,106,.2);color:var(--red);border:1px solid var(--red)!important}
.ev-card{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:16px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
.ev-card:hover{transform:translateY(-2px);border-color:var(--cyan)}
.ev-card.critico{border-left:4px solid var(--red)}
.ev-card.alerta{border-left:4px solid var(--amber)}
.ev-card.ok{border-left:4px solid var(--green)}
.ev-card.execucao{border-left:4px solid var(--cyan)}
.ev-card-titulo{font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px}
.ev-card-valor{font-size:32px;font-weight:800;font-family:'DM Mono',monospace;margin-bottom:4px}
.ev-card-desc{font-size:11px;color:var(--muted)}
.ev-card-pulse{position:absolute;top:12px;right:12px;width:8px;height:8px;border-radius:50%;animation:pulse 2s infinite}
.ev-card-pulse.red{background:var(--red)}
.ev-card-pulse.amber{background:var(--amber)}
.ev-card-pulse.green{background:var(--green)}
.ev-card-pulse.cyan{background:var(--cyan)}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.3)}}
.ev-modal-item{padding:10px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:12px;display:flex;justify-content:space-between;align-items:center}
.ev-modal-item:last-child{border:none}
.ev-recomendacao{margin-top:14px;padding:12px 14px;border:1px solid var(--amber);border-radius:8px;background:rgba(255,184,63,.08);font-size:12px;color:var(--amber)}
.ev-ws-item{display:flex;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.03);font-size:11px}
.ev-ws-item:last-child{border:none}
.ag-alert.critico{background:rgba(255,77,106,.15);color:var(--red)}
.ag-alert.aviso{background:rgba(255,184,63,.15);color:var(--amber)}
.ag-alert.info{background:rgba(0,212,255,.1);color:var(--cyan)}
.det-kpi{background:var(--s2);border-radius:8px;padding:12px}
.det-kpi-lbl{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
.det-kpi-val{font-size:20px;font-weight:800;font-family:'DM Mono',monospace}
.checklist-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:12px}
.checklist-row:last-child{border:none}
.chk-ok{color:var(--green)}
.chk-fail{color:var(--red)}
.chk-warn{color:var(--amber)}
.lista-os-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.04);cursor:pointer;transition:background .15s;border-radius:6px}
.lista-os-row:hover{background:rgba(255,255,255,.03)}
.lista-os-row:last-child{border:none}
.lista-os-id{font-family:'DM Mono',monospace;font-size:12px;color:var(--muted);min-width:70px}
.lista-os-info{flex:1}
.lista-os-tec{font-size:11px;color:var(--muted)}
.lista-os-pts{font-family:'DM Mono',monospace;font-size:14px;font-weight:700;min-width:50px;text-align:right}
.os-status-chip.agendada{background:rgba(0,212,255,.12);color:var(--cyan)}
.os-status-chip.aguardando{background:rgba(255,184,63,.12);color:var(--amber)}
.os-status-chip.execucao,.os-status-chip.aberta{background:rgba(167,139,250,.12);color:var(--purple)}

/* Técnico row */
.tec-row{display:flex;align-items:center;padding:8px 10px;border-radius:7px;background:var(--s2);border:1px solid var(--border);margin-bottom:5px;cursor:pointer;transition:all .2s}
.tec-row:hover{border-color:rgba(0,212,255,.25);transform:translateX(2px)}

/* ══ MODAIS ════════════════════════════════════════ */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.8);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;z-index:9000;padding:20px}
.modal-overlay.active{display:flex;animation:fadeIn .2s ease}
.modal{background:var(--s1);border:1px solid var(--border);border-radius:14px;width:100%;max-width:720px;max-height:85vh;overflow:hidden;display:flex;flex-direction:column;animation:slideUp .25s cubic-bezier(.4,0,.2,1);box-shadow:0 28px 70px rgba(0,0,0,.7)}
.modal.wide{max-width:900px}
.modal-header{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-shrink:0}
.modal-header-left{display:flex;flex-direction:column;gap:3px;min-width:0}
.modal-title{font-size:14px;font-weight:800}
.modal-sub{font-size:10px;color:var(--muted);font-family:'DM Mono',monospace}
.modal-close{background:var(--s2);border:1px solid var(--border);color:var(--muted);width:28px;height:28px;border-radius:7px;display:grid;place-items:center;cursor:pointer;font-size:16px;transition:all .2s;flex-shrink:0}
.modal-close:hover{border-color:var(--red);color:var(--red)}
.modal-hd{display:flex!important;justify-content:space-between!important;align-items:flex-start!important;flex-shrink:0}
.modal-hd>div{flex:1;min-width:0}
.modal-hd>.modal-close{flex-shrink:0;margin-left:12px}

/* Tabs dentro do modal */
.modal-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);padding:0 20px;flex-shrink:0}
.modal-tab{padding:10px 16px;font-size:11px;font-weight:700;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap}
.modal-tab:hover{color:var(--text)}
.modal-tab.active{color:var(--cyan);border-bottom-color:var(--cyan)}
.modal-tab-content{display:none;padding:16px 20px;overflow-y:auto;flex:1}
.modal-tab-content.active{display:block}

/* Stats do modal */
.modal-stats{display:flex;border-bottom:1px solid var(--border);flex-shrink:0}
.modal-stat{flex:1;padding:10px 14px;text-align:center;border-right:1px solid var(--border)}
.modal-stat:last-child{border-right:none}
.modal-stat-val{font-size:18px;font-weight:800;font-family:'DM Mono',monospace;color:var(--cyan);line-height:1}
.modal-stat-lbl{font-size:8px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-top:2px}

/* SLA bar */
.sla-bar{height:8px;background:var(--border);border-radius:4px;margin:8px 0;overflow:hidden}
.sla-bar-fill{height:8px;border-radius:4px;transition:width 1s ease}

/* ══ AGENDA ════════════════════════════════════════ */
.agenda-grid{display:flex;flex-direction:column;gap:10px}
.agenda-tec{background:var(--s2);border:1px solid var(--border);border-radius:10px;overflow:hidden}
.agenda-tec-header{display:flex;align-items:center;gap:8px;padding:10px 14px;background:var(--s3);border-bottom:1px solid var(--border);cursor:pointer}
.agenda-tec-nome{font-size:12px;font-weight:700;flex:1}
.agenda-tec-count{font-family:'DM Mono',monospace;font-size:11px;color:var(--cyan)}
.agenda-os{padding:8px 14px}
.agenda-os-item{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.03);cursor:pointer}
.agenda-os-item:last-child{border-bottom:none}
.agenda-os-item:hover .agenda-os-id{color:var(--cyan)}
.agenda-hora{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);width:50px;flex-shrink:0}
.agenda-os-id{font-family:'DM Mono',monospace;font-size:10px;font-weight:700;color:var(--sub);width:60px;flex-shrink:0;transition:color .2s}
.agenda-os-nome{font-size:11px;font-weight:600;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* ══ CENTRAL OPERACIONAL ═══════════════════════════ */
.critico-card{background:var(--s2);border:1px solid rgba(255,77,106,.2);border-radius:9px;padding:12px 14px;margin-bottom:8px;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:10px}
.critico-card:hover{border-color:rgba(255,77,106,.4);transform:translateX(2px)}
.critico-card.amber{border-color:rgba(255,184,63,.2)}
.critico-card.amber:hover{border-color:rgba(255,184,63,.4)}
.critico-icon{font-size:18px;flex-shrink:0}
.critico-info{flex:1;min-width:0}
.critico-titulo{font-size:12px;font-weight:700}
.critico-sub{font-size:10px;color:var(--muted);margin-top:2px}
.critico-badge{flex-shrink:0}

/* ══ MODO TV ════════════════════════════════════════ */
#tv-overlay{
  position:fixed;inset:0;background:var(--bg);z-index:9999;
  display:none;flex-direction:column;padding:24px;
  font-family:'Bricolage Grotesque',sans-serif;
}
#tv-overlay.active{display:flex}
.tv-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.tv-logo{font-size:18px;font-weight:800;color:var(--cyan)}
.tv-clock{font-family:'DM Mono',monospace;font-size:28px;font-weight:700;color:var(--text)}
.tv-date{font-size:12px;color:var(--muted);text-align:right}
.tv-body{display:grid;grid-template-columns:2fr 1fr;gap:20px;flex:1;overflow:hidden}
.tv-left{display:flex;flex-direction:column;gap:16px}
.tv-right{display:flex;flex-direction:column;gap:16px}
.tv-kpis{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.tv-kpi{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:16px;text-align:center;position:relative;overflow:hidden}
.tv-kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--ac,var(--cyan))}
.tv-kpi-val{font-size:36px;font-weight:800;font-family:'DM Mono',monospace;color:var(--ac,var(--cyan));line-height:1}
.tv-kpi-lbl{font-size:11px;color:var(--muted);margin-top:4px;text-transform:uppercase;letter-spacing:.1em}
.tv-section{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:14px;flex:1;overflow:hidden;display:flex;flex-direction:column}
.tv-section-title{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin-bottom:12px;display:flex;align-items:center;gap:7px}
.tv-section-title::after{content:'';flex:1;height:1px;background:var(--border)}
.tv-ranking-item{display:flex;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.03)}
.tv-ranking-item:last-child{border-bottom:none}
.tv-rank-pos{width:22px;height:22px;border-radius:5px;display:grid;place-items:center;font-size:10px;font-weight:800;font-family:'DM Mono',monospace;margin-right:8px;flex-shrink:0}
.tv-rank-nome{flex:1;font-size:13px;font-weight:700}
.tv-rank-os{font-family:'DM Mono',monospace;font-size:14px;font-weight:800;color:var(--cyan);margin-right:8px}
.tv-recent-item{padding:8px 0;border-bottom:1px solid rgba(255,255,255,.03);font-size:11px}
.tv-recent-item:last-child{border-bottom:none}
.tv-recent-id{font-family:'DM Mono',monospace;font-size:10px;color:var(--cyan);margin-right:6px}
.tv-btn-close{position:absolute;top:16px;right:16px;background:var(--s2);border:1px solid var(--border);color:var(--muted);padding:6px 14px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:700;font-family:'Bricolage Grotesque',sans-serif}
.tv-btn-close:hover{border-color:var(--red);color:var(--red)}

/* TV Popup */
#tv-popup-container{position:fixed;bottom:24px;right:24px;z-index:10000;display:flex;flex-direction:column;gap:10px;align-items:flex-end}
.tv-popup{
  background:var(--s1);border:1px solid var(--border);border-radius:12px;
  padding:14px 18px;min-width:280px;max-width:340px;
  box-shadow:0 8px 32px rgba(0,0,0,.5);
  animation:slideUp .3s ease;
}
.tv-popup.green{border-color:rgba(0,229,160,.3);box-shadow:0 8px 32px rgba(0,229,160,.1)}
.tv-popup.red{border-color:rgba(255,77,106,.3);box-shadow:0 8px 32px rgba(255,77,106,.1)}
.tv-popup.amber{border-color:rgba(255,184,63,.3);box-shadow:0 8px 32px rgba(255,184,63,.1)}
.tv-popup-header{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.tv-popup-icon{font-size:16px}
.tv-popup-titulo{font-size:12px;font-weight:800;flex:1}
.tv-popup-sub{font-size:10px;color:var(--muted)}
.tv-popup-bar{height:2px;background:rgba(255,255,255,.1);border-radius:1px;margin-top:8px;overflow:hidden}
.tv-popup-bar-fill{height:2px;border-radius:1px;transition:width linear}
.tv-popup-bar-fill.green{background:var(--green)}
.tv-popup-bar-fill.red{background:var(--red)}
.tv-popup-bar-fill.amber{background:var(--amber)}

/* Meta progress */
.meta-track{background:var(--border);border-radius:5px;height:6px;margin-top:8px;overflow:hidden}
.meta-fill{height:6px;border-radius:5px;transition:width 1.2s cubic-bezier(.4,0,.2,1)}

/* Tabs de período */
.period-tabs{display:flex;gap:4px;margin-bottom:12px}
.period-tab{padding:4px 12px;border-radius:5px;font-size:10px;font-weight:700;cursor:pointer;border:1px solid var(--border);color:var(--muted);background:transparent;transition:all .15s;font-family:'Bricolage Grotesque',sans-serif}
.period-tab.active{background:rgba(0,212,255,.1);border-color:rgba(0,212,255,.2);color:var(--cyan)}
.period-tab:hover:not(.active){color:var(--text)}

@media(max-width:1100px){.kpi-grid.c5{grid-template-columns:repeat(3,1fr)}.card-grid.c3{grid-template-columns:1fr 1fr}}
</style>
