async function loadAuditoriaIndividual(){
  const tecIds=_filtros.tecnico||[]
  const di=document.getElementById('f-data-inicio')?.value
  const df=document.getElementById('f-data-fim')?.value
  const kpis=document.getElementById('audit-ind-kpis')
  const el=document.getElementById('audit-ind-content')
  if(!el)return
  const semTec='<div style="color:var(--muted);font-size:13px;padding:20px;display:flex;align-items:center;gap:8px"><span style="font-size:20px">👆</span> Selecione 1 <strong style="color:var(--text)">técnico</strong> no filtro do topo e clique em <strong style="color:var(--cyan)">Aplicar</strong>.</div>'
  if(tecIds.length===0){el.innerHTML=semTec;if(kpis){kpis.style.display='none';kpis.innerHTML=''}return}
  if(tecIds.length>1){el.innerHTML='<div style="color:var(--amber);font-size:13px;padding:20px">⚠️ Selecione apenas <strong>1 técnico</strong> no filtro.</div>';if(kpis){kpis.style.display='none';kpis.innerHTML=''}return}
  el.innerHTML='<div class="loading"><div class="spinner"></div>Carregando auditoria...</div>'
  let tecId=null,tecNome='---'
  try{
    const tlist=await apiFetch('/api/tecnicos/')
    const tecs=tlist.tecnicos||tlist
    const tec=tecs.find(t=>String(t.ixc_funcionario_id)===String(tecIds[0])||String(t.id)===String(tecIds[0]))
    if(tec){tecId=tec.id;tecNome=tec.nome}
  }catch(e){console.error(e)}
  if(!tecId){el.innerHTML='<div style="color:var(--red);padding:20px">Tecnico nao encontrado.</div>';return}
  let url='/api/sais/produtividade/auditoria/'+tecId
  const params=[]
  if(di)params.push('data_inicio='+di)
  if(df)params.push('data_fim='+df)
  if(params.length)url+='?'+params.join('&')
  try{
    const d=await apiFetch(url)
    const r=d.resumo
    const os=d.os||[]
    if(kpis){
      kpis.style.display='grid'
      const corMeta=r.pct_meta>=80?'var(--green)':r.pct_meta>=50?'var(--amber)':'var(--red)'
      kpis.innerHTML='<div class="kpi" style="--ac:var(--cyan)"><div class="kpi-val">'+r.total_os+'</div><div class="kpi-lbl">OS Finalizadas</div></div>'
        +'<div class="kpi" style="--ac:var(--green)"><div class="kpi-val">'+r.pontos_ganhos+'</div><div class="kpi-lbl">Pontos Ganhos</div></div>'
        +'<div class="kpi" id="kpi-perdidos" style="--ac:var(--red);cursor:pointer"><div class="kpi-val">'+r.pontos_perdidos+'</div><div class="kpi-lbl">Pontos Perdidos ▾</div></div>'
        +'<div class="kpi" id="kpi-bonus" style="--ac:var(--yellow);cursor:pointer"><div class="kpi-val">'+r.bonus_total+'</div><div class="kpi-lbl">Bônus ▾</div></div>'
        +'<div class="kpi" style="--ac:'+corMeta+'"><div class="kpi-val">'+r.pct_meta+'%</div><div class="kpi-lbl">Meta ('+r.meta_periodo+' pts)</div></div>'
        +(r.sem_regra>0?'<div class="kpi" id="kpi-semregra" style="--ac:var(--muted);cursor:pointer"><div class="kpi-val">'+r.sem_regra+'</div><div class="kpi-lbl">Sem Regra ▾</div></div>':'')
    }
    // Bind onclick nos KPIs — precisa vir APÓS kpis.innerHTML ser preenchido
    ;['perdidos','bonus','semregra'].forEach(function(f){
      var k=document.getElementById('kpi-'+f)
      if(k) k.onclick=function(){toggleAuditFiltro(f)}
    })

    if(!os.length){el.innerHTML='<div style="color:var(--muted);padding:20px">Nenhuma OS no periodo.</div>';return}

    // Guarda OS para filtro por KPI
    window._auditOsData = os
    window._auditFiltro = null

    window._renderAuditTabela = function(filtro){
      window._auditFiltro = filtro
      // Atualiza visual dos KPIs
      ;['perdidos','bonus','semregra'].forEach(function(f){
        const k=document.getElementById('kpi-'+f)
        if(k) k.style.outline = filtro===f?'2px solid var(--cyan)':'none'
      })
      const lista = filtro==='perdidos' ? os.filter(function(o){return o.perdidos>0})
                  : filtro==='bonus'    ? os.filter(function(o){return o.bonus&&o.bonus.length>0})
                  : filtro==='semregra' ? os.filter(function(o){return !o.calculado})
                  : os
      let rows=''
      lista.forEach(function(o){
      const cor=o.perdidos>0?'var(--red)':o.pontos_final>0?'var(--green)':'var(--muted)'
      const pens=o.penalidades.map(function(p){return '<span style="color:var(--red);font-size:10px">'+p.motivo+'('+p.valor+')</span>'}).join(' · ')
      const bon=o.bonus.map(function(b){return '<span style="color:var(--green);font-size:10px">'+b.motivo+'(+'+b.valor+')</span>'}).join(' · ')
      const sr=!o.calculado?'<span style="color:var(--muted);font-size:10px">sem regra</span>':''
      const catCor=o.categoria==='servico'?'green':o.categoria==='suporte'?'amber':o.categoria==='infra'?'blue':'red'
      rows+='<tr style="border-bottom:1px solid rgba(255,255,255,.04);cursor:pointer" onclick="abrirModalOS('+o.os_id+')">'
        +'<td style="padding:7px 6px;color:var(--muted)">'+o.data+'</td>'
        +'<td style="padding:7px 6px;color:var(--cyan);font-family:monospace">#'+o.os_id+'</td>'
        +'<td style="padding:7px 6px;font-weight:600;max-width:180px">'+o.nome_assunto+'</td>'
        +'<td style="padding:7px 6px"><span class="badge '+catCor+'" style="font-size:9px">'+o.categoria+'</span></td>'
        +'<td style="padding:7px 6px;text-align:center;color:var(--muted)">'+o.pontos_base+'</td>'
        +'<td style="padding:7px 6px;text-align:center;font-weight:700;color:'+cor+'">'+o.pontos_final+'</td>'
        +'<td style="padding:7px 6px;text-align:center;color:var(--red)">'+(o.perdidos>0?'-'+o.perdidos:'')+'</td>'
        +'<td style="padding:7px 6px;line-height:1.8">'+sr+pens+bon+'</td>'
        +'<td style="padding:7px 6px;text-align:center">'+(o.evidencias.fotos||0)+'</td>'
        +'<td style="padding:7px 6px;text-align:center">'+(o.evidencias.tem_app?'OK':'--')+'</td>'
        +'<td style="padding:7px 6px;text-align:center">'
        +(o.revisada?'<span style="color:var(--green);font-size:10px">✅</span> ':'')
        +'<button style="background:rgba(255,255,255,.08);border:none;color:var(--text);padding:3px 8px;border-radius:6px;cursor:pointer;font-size:11px" '
        +'onclick="event.stopPropagation();abrirEditOS('+o.os_id+',\''+o.nome_assunto+'\',' +o.pontos_base+',\''+o.pendencias_txt+'\','+(o.pontos_override!=null?o.pontos_override:'null')+',\''+( o.obs_manual||'')+'\',' +o.revisada+',\''+( o.revisado_por||'')+'\')">✏️</button>'
        +'</td>'
        +'</tr>'
    })
      el.innerHTML='<div style="overflow-x:auto"><table style="width:100%;border-collapse:collapse;font-size:12px">'
        +'<thead><tr style="border-bottom:1px solid var(--border);color:var(--muted);text-align:left">'
        +'<th style="padding:8px 6px">Data</th><th style="padding:8px 6px">OS</th><th style="padding:8px 6px">Assunto</th>'
        +'<th style="padding:8px 6px">Cat.</th><th style="padding:8px 6px;text-align:center">Base</th>'
        +'<th style="padding:8px 6px;text-align:center">Final</th><th style="padding:8px 6px;text-align:center">Perdido</th>'
        +'<th style="padding:8px 6px">Penalidades/Bonus</th><th style="padding:8px 6px;text-align:center">Fotos</th>'
        +'<th style="padding:8px 6px;text-align:center">App</th><th style="padding:8px 6px;text-align:center">Ação</th></tr></thead>'
        +'<tbody>'+rows+'</tbody></table></div>'
      if(!lista.length) el.innerHTML='<div style="color:var(--muted);padding:20px">Nenhuma OS neste filtro.</div>'
    }
    window._renderAuditTabela(null)
  }catch(e){el.innerHTML='<div style="color:var(--red);padding:20px">Erro: '+e.message+'</div>';console.error(e)}
}

