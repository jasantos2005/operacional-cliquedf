async function abrirModalTecnico(tecId,tecNome,isIxcId=false){
  document.getElementById('modal-tec-title').textContent=tecNome||'Técnico'
  document.getElementById('modal-tec-sub').textContent='Carregando...'
  document.getElementById('modal-tec-stats').innerHTML=''
  switchTab('tec','hoje',document.querySelector('#modal-tec .modal-tab'))
  document.getElementById('tec-tab-hoje').innerHTML=`<div class="loading"><div class="spinner"></div>Carregando...</div>`
  abrirModal('modal-tec')

  try{
    // Usa data do filtro da topbar
    const di = document.getElementById('f-data-inicio')?.value || ''
    const df = document.getElementById('f-data-fim')?.value || ''
    const fp = getFiltrosParams()
    // Se for ixc_funcionario_id, busca o id interno primeiro
    let idInterno = tecId
    if(isIxcId){
      const tecs = await apiFetch('/api/tecnicos/')
      const tec = (tecs||[]).find(t => t.ixc_funcionario_id == tecId)
      if(tec) idInterno = tec.id
    }
    const qs = fp ? `?${fp}` : (di ? `?data=${di}` : '')
    const d=await apiFetch(`${SAIS}/visao-geral/tecnico/${idInterno}${qs}`)
    const t=d.tecnico||{}
    const hoje=d.hoje||{}
    const score=d.score||{}

    document.getElementById('modal-tec-sub').textContent=
      `ID IXC: ${t.ixc_funcionario_id||'—'} · Meta: ${t.meta_dia||8} OS/dia`

    // Stats header
    document.getElementById('modal-tec-stats').innerHTML=`
      <div class="modal-stat"><div class="modal-stat-val">${hoje.total||0}</div><div class="modal-stat-lbl">Total OS</div></div>
      <div class="modal-stat"><div class="modal-stat-val" style="color:var(--green)">${hoje.finalizadas||0}</div><div class="modal-stat-lbl">Finalizadas</div></div>
      <div class="modal-stat"><div class="modal-stat-val" style="color:var(--amber)">${hoje.em_campo||0}</div><div class="modal-stat-lbl">Em Campo</div></div>
      <div class="modal-stat"><div class="modal-stat-val" style="color:var(--cyan)">${score.score_final||0}</div><div class="modal-stat-lbl">Score</div></div>
      <div class="modal-stat"><div class="modal-stat-val" style="color:${score.pct_meta>=80?'var(--green)':score.pct_meta>=50?'var(--amber)':'var(--red)'}">${score.pct_meta||0}%</div><div class="modal-stat-lbl">Meta</div></div>
    `

    // Tab Hoje
    document.getElementById('tec-tab-hoje').innerHTML=`
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px">
        ${statBox('Finalizadas', hoje.finalizadas||0, 'var(--green)')}
        ${statBox('Em Campo', hoje.em_campo||0, 'var(--amber)')}
        ${statBox('Agendadas', hoje.agendadas||0, 'var(--cyan)')}
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px">
        ${Object.entries(score.por_categoria||{}).map(([cat,v])=>{
          const total = typeof v === 'object' ? (v.os||v.pontos||0) : v
          return `<div style="background:var(--s2);border-radius:6px;padding:8px;text-align:center">
            <div style="font-size:16px;font-weight:800;color:${catCor(cat)}">${total}</div>
            <div style="font-size:9px;color:var(--muted);text-transform:capitalize">${cat}</div>
          </div>`
        }).join('')}
      </div>
    `

    // Tab Agenda
    document.getElementById('tec-tab-agenda').innerHTML=(d.agenda||[]).length
      ?d.agenda.map(o=>`
        <div class="agenda-os-item" onclick="abrirModalOSAg(${o.ixc_os_id})">
          <span class="agenda-hora">${fmtHora(o.data_agenda)}</span>
          <span class="agenda-os-id">#${o.ixc_os_id}</span>
          <span class="agenda-os-nome">${o.assunto||'—'}</span>
        </div>
      `).join('')
      :`<div class="empty"><div class="empty-icon">📅</div>Nenhuma OS agendada</div>`

    // Tab Produtividade
    const hist=d.historico_7d||[]
    document.getElementById('tec-tab-produtividade').innerHTML=`
      <div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px">Histórico 7 dias</div>
      <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:6px">
        ${hist.map(h=>`
          <div style="background:var(--s2);border-radius:6px;padding:8px 4px;text-align:center">
            <div style="font-size:14px;font-weight:800;color:var(--cyan)">${h.total_os}</div>
            <div style="font-size:8px;color:var(--muted)">${h.data.slice(5)}</div>
            <div style="font-size:9px;color:${h.eficiencia>=80?'var(--green)':'var(--amber)'}">${h.eficiencia}%</div>
          </div>
        `).join('')}
      </div>
    `

    // Tab Auditoria
    document.getElementById('tec-tab-auditoria').innerHTML=(d.auditorias||[]).length
      ?d.auditorias.map(a=>`
        <div class="critico-card ${criticidadeCls(a.criticidade)}" style="margin-bottom:7px">
          <div class="critico-icon">🔍</div>
          <div class="critico-info">
            <div class="critico-titulo">${a.subtipo} ${a.os_id?'· OS #'+a.os_id:''}</div>
            <div class="critico-sub">${a.descricao||''}</div>
          </div>
          <span class="badge ${criticidadeCls(a.criticidade)}">${a.criticidade}</span>
        </div>
      `).join('')
      :`<div class="empty"><div class="empty-icon">✅</div>Sem ocorrências de auditoria</div>`

    // Tab OS Recentes
    document.getElementById('tec-tab-os-recentes').innerHTML=(d.os_recentes||[]).length
      ?d.os_recentes.map(o=>`
        <div class="os-row" onclick="abrirModalOS(${o.ixc_os_id})">
          <div class="os-id">#${o.ixc_os_id}</div>
          <div class="os-info">
            <div class="os-assunto">${o.assunto||'—'}</div>
            <div class="os-meta"><span>${fmtData(o.data_fechamento||o.data_agenda||o.data_abertura)}</span></div>
          </div>
          <span class="os-status-chip ${statusCls(o.status)}">${statusLabel(o.status)}</span>
        </div>
      `).join('')
      :`<div class="empty"><div class="empty-icon">📋</div>Nenhuma OS recente</div>`

  }catch(e){
    document.getElementById('tec-tab-hoje').innerHTML=`<div class="empty"><div class="empty-icon">⚠️</div>Erro ao carregar técnico</div>`
  }
}

