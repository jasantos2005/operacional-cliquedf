            ${infoRow('Assunto', os.nome_assunto||'—')}
            ${infoRow('Categoria', os.categoria||'—')}
            ${infoRow('Status', `<span class="badge ${statusCls(os.status)}">${statusLabel(os.status)}</span>`)}
          </div>
        </div>
        <div>
          <div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px">Datas</div>
          <div style="display:flex;flex-direction:column;gap:6px">
            ${infoRow('Abertura', fmtData(os.data_abertura))}
            ${infoRow('Agenda', fmtData(os.data_agenda)||'—')}
            ${infoRow('Fechamento', fmtData(os.data_fechamento)||'—')}
          </div>
        </div>
      </div>
