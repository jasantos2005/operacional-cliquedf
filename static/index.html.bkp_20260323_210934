function renderMeta(d){
  const fins        = d.resumo?.finalizadas || 0
  const totalPontos = d.total_pontos  || 0
  const metaPeriodo = d.meta_periodo  || 1760
  const diasUteis   = d.dias_uteis    || 1
  const pct  = Math.min(metaPeriodo > 0 ? Math.round(totalPontos / metaPeriodo * 100) : 0, 100)
  const cor  = pct >= 80 ? 'var(--green)' : pct >= 50 ? 'var(--amber)' : 'var(--red)'
