    // Tab Pontuação
    if(pont.calculado){
      const det=pont.detalhes||{}
      const ev=pont.evidencias||{}
      const pends=pont.pendencias||[]
      const pct=pont.pontos_base>0?Math.round(pont.pontos_final/pont.pontos_base*100):0
