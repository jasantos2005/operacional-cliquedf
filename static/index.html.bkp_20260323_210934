function abrirModal(id){document.getElementById(id).classList.add('active')}
function fecharModal(id){document.getElementById(id).classList.remove('active')}
function overlayClick(e,id){if(e.target===e.currentTarget)fecharModal(id)}
document.addEventListener('keydown',e=>{
  if(e.key!=='Escape') return
  const abertos=[...document.querySelectorAll('.modal-overlay.active')]
  if(abertos.length) fecharModal(abertos[abertos.length-1].id)
})

function switchTab(modalId, tabId, el){
  // Desativar todas as tabs e conteúdos
  const modal=document.getElementById('modal-'+modalId)
  modal.querySelectorAll('.modal-tab').forEach(t=>t.classList.remove('active'))
  modal.querySelectorAll('.modal-tab-content').forEach(t=>t.classList.remove('active'))
  // Ativar a tab clicada
  if(el) el.classList.add('active')
  const content=document.getElementById(`${modalId}-tab-${tabId}`)
  if(content) content.classList.add('active')
}

