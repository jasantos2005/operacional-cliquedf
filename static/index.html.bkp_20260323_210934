let _editOsAtual = null

function abrirEditOS(osId, assunto, pontosAuto, pendencias, pontosOverride, obs, revisada, revisadoPor){
  _editOsAtual = osId
  document.getElementById('edit-os-id').textContent = '#' + osId
  document.getElementById('edit-os-assunto').textContent = assunto || ''
  document.getElementById('edit-os-pontos-auto').textContent = pontosAuto + ' pts'
  document.getElementById('edit-os-pendencias').textContent = pendencias || ''
  document.getElementById('edit-pontos-input').value = pontosOverride != null ? pontosOverride : ''
  document.getElementById('edit-obs-input').value = obs || ''
  document.getElementById('edit-revisada-input').checked = !!revisada
  document.getElementById('edit-revisor-input').value = revisadoPor || ''
  const m = document.getElementById('modal-edit-os')
  m.style.display = 'flex'
}

function fecharEditOS(){
  document.getElementById('modal-edit-os').style.display = 'none'
  _editOsAtual = null
}

async function salvarEditOS(){
  if(!_editOsAtual) return
  const pontosInput = document.getElementById('edit-pontos-input').value.trim()
  const obs         = document.getElementById('edit-obs-input').value.trim()
  const revisada    = document.getElementById('edit-revisada-input').checked ? 1 : 0
  const revisor     = document.getElementById('edit-revisor-input').value.trim()

  const params = []
  if(pontosInput !== '') params.push('pontos_override=' + parseInt(pontosInput))
  if(obs)                params.push('obs_manual='      + encodeURIComponent(obs))
  params.push('revisada=' + revisada)
  if(revisor)            params.push('revisado_por='    + encodeURIComponent(revisor))

  try {
    const url = '/api/sais/produtividade/auditoria/os/' + _editOsAtual + '?' + params.join('&')
    const r = await fetch(url, {method:'PATCH'})
    const d = await r.json()
    if(d.ok){
      fecharEditOS()
      loadAuditoriaIndividual()
    } else {
      alert('Erro: ' + (d.erro || 'Falha ao salvar'))
    }
  } catch(e){
    alert('Erro de comunicação: ' + e.message)
  }
}


