function globalFiltroChange(){
  // Invalida cache de opções quando período muda
  if(_filtroOpcoes) _filtroOpcoes._chave = null
  atualizarBotoesFiltro()
  const paginasReativas = ['dashboard','ranking','agenda-dia','auditoria','os-atrasadas','tecnicos-ociosos','ultimas-os','prod-assunto','prod-auditoria']
  if(paginasReativas.includes(currentPage)){
    const cfg = PAGES_CFG[currentPage]
    if(cfg?.load) cfg.load()
  }
}

function atualizarBotoesFiltro(){
  const tipos = ['tecnico','categoria','cidade','bairro','concentrador','assunto']
  const labels = {tecnico:'👷 Técnicos',categoria:'📂 Categoria',cidade:'🏙️ Cidade',bairro:'📍 Bairro',concentrador:'🔌 Concentrador',assunto:'📋 Serviço'}
  let total = 0
  tipos.forEach(t=>{
    const btn = document.getElementById('fb-'+t)
    if(!btn) return
    const cnt = (_filtros[t]||[]).length
    total += cnt
    btn.classList.toggle('ativo', cnt>0)
    btn.textContent = cnt > 0 ? `${labels[t]} (${cnt})` : labels[t]
  })
  const di = document.getElementById('f-data-inicio')?.value
  const df = document.getElementById('f-data-fim')?.value
  if(di||df) total++
  const clearBtn = document.getElementById('filtro-clear-btn')
  if(clearBtn) clearBtn.style.display = total > 0 ? '' : 'none'
  // mantém compatibilidade com fmAtualizar se existir
  if(typeof fmAtualizar === 'function') fmAtualizar()
}



function getFiltrosParams(){
  const p = new URLSearchParams()
  const di = document.getElementById('f-data-inicio')?.value
  const df = document.getElementById('f-data-fim')?.value
  if(di) p.set('data_inicio', di)
  if(df) p.set('data_fim', df)
  if(_filtros.tecnico.length)      p.set('tecnico_id',    _filtros.tecnico.join(','))
  if(_filtros.categoria.length)    p.set('categoria',     _filtros.categoria.join(','))
  if(_filtros.cidade.length)       p.set('cidade',        _filtros.cidade.join(','))
  if(_filtros.bairro.length)       p.set('bairro',        _filtros.bairro.join(','))
  if(_filtros.concentrador.length) p.set('concentrador',  _filtros.concentrador.join(','))
  if(_filtros.assunto.length)      p.set('assunto_id',    _filtros.assunto.join(','))
  return p.toString()
}

function temFiltrosAtivos(){
  const di = document.getElementById('f-data-inicio')?.value
  const df = document.getElementById('f-data-fim')?.value
  return !!(di || df || Object.values(_filtros).some(v=>v.length>0))
}

