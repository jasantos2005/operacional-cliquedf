}

// ═══════════════════════════════════════════════════
// AGENDA
// ═══════════════════════════════════════════════════
async function loadAgendaDia(offsetDias=0, btn=null){
  if(btn){document.querySelectorAll('#page-agenda-dia .period-tab').forEach(t=>t.classList.remove('active'));btn.classList.add('active')}
  const data=new Date(Date.now()+(offsetDias-3)*0 ) // offset simples
  const dataStr=new Date(new Date().getTime()+(offsetDias*86400000)).toISOString().split('T')[0]
  const d=await apiFetch(`${SAIS}/agenda/dia?data=${dataStr}`)
  document.getElementById('agenda-dia-sub').textContent=`${d.total||0} OS agendadas para ${dataStr}`
  const el=document.getElementById('agenda-dia-content')
  if(!d.por_tecnico?.length){el.innerHTML=`<div class="empty"><div class="empty-icon">📅</div>Nenhuma OS agendada</div>`;return}
  el.innerHTML=d.por_tecnico.map(t=>`
    <div class="agenda-tec">
      <div class="agenda-tec-header" onclick="abrirModalTecnico(${t.tecnico_id},'${esc(t.nome)}')">
        <span style="font-size:14px">👷</span>
        <span class="agenda-tec-nome">${t.nome}</span>
        <span class="agenda-tec-count">${t.os.length} OS</span>
      </div>
      <div class="agenda-os">
        ${t.os.map(o=>`
          <div class="agenda-os-item" onclick="abrirModalOS(${o.ixc_os_id})">
            <span class="agenda-hora">${fmtHora(o.data_agenda)}</span>
            <span class="agenda-os-id">#${o.ixc_os_id}</span>
            <span class="agenda-os-nome">${o.assunto||'—'}</span>
            <span class="badge cyan" style="flex-shrink:0">${o.categoria||'—'}</span>
          </div>
        `).join('')}
      </div>
    </div>
  `).join('')
}

async function loadAgendaFutura(){
  const d=await apiFetch(`${SAIS}/agenda/futura?dias=7`)
  const el=document.getElementById('agenda-futura-content')
  if(!d.agenda_futura?.length){el.innerHTML=`<div class="empty"><div class="empty-icon">📅</div>Nenhuma OS agendada nos próximos 7 dias</div>`;return}
  el.innerHTML=`<div class="card"><div class="tbl-wrap"><table>
    <thead><tr><th>Data</th><th class="r">Total</th><th class="r">Serviço</th><th class="r">Suporte</th><th class="r">Infra</th><th class="r">Retirada</th></tr></thead>
    <tbody>${d.agenda_futura.map(r=>`
      <tr onclick="loadAgendaDiaData('${r.data}')">
        <td><strong>${r.data}</strong></td>
        <td class="r" style="color:var(--cyan);font-weight:700">${r.total}</td>
        <td class="r">${r.servicos||0}</td>
        <td class="r">${r.suportes||0}</td>
        <td class="r">${r.infra||0}</td>
        <td class="r">${r.retiradas||0}</td>
      </tr>
    `).join('')}</tbody>
  </table></div></div>`
}

async function loadReagendamentos(){
  const d=await apiFetch(`${SAIS}/agenda/reagendamentos?limit=30`)
  const el=document.getElementById('reagendamentos-list')
  if(!d.reagendamentos?.length){el.innerHTML=`<div class="empty"><div class="empty-icon">✅</div>Nenhuma OS reagendada pendente</div>`;return}
  el.innerHTML=d.reagendamentos.map(o=>`
    <div class="os-row" onclick="abrirModalOS(${o.ixc_os_id})">
      <div class="os-id">#${o.ixc_os_id}</div>
      <div class="os-info">
        <div class="os-assunto">${o.assunto||'—'}</div>
        <div class="os-meta"><span>${o.tecnico||'—'}</span><span>Agendada para ${fmtData(o.data_agenda)}</span><span style="color:var(--red)">${o.horas_atraso}h de atraso</span></div>
      </div>
      <span class="badge red">${o.horas_atraso}h</span>
    </div>
  `).join('')
}

// ═══════════════════════════════════════════════════
// RANKING / PRODUTIVIDADE
// ═══════════════════════════════════════════════════
async function loadRanking(data,btn=null){
  if(btn){document.querySelectorAll('#page-ranking .period-tab').forEach(t=>t.classList.remove('active'));btn.classList.add('active')}
  const url=data?`${SAIS}/pontuacao/ranking?data=${data}`:`${SAIS}/pontuacao/ranking`
  const d=await apiFetch(url)
  document.getElementById('ranking-table').innerHTML=(d.ranking||[]).map((t,i)=>`
    <tr onclick="abrirModalTecnico(${t.tecnico_id},'${esc(t.nome)}')">
      <td><span class="rpos ${rposCls(i)}">${i+1}</span></td>
      <td><strong>${t.nome}</strong></td>
      <td class="r" style="color:var(--cyan);font-weight:700">${t.total_os}</td>
      <td class="r"><span class="badge cyan" style="font-family:'DM Mono',monospace;font-size:13px">${t.total_pontos}</span></td>
      <td class="r"><span class="badge ${t.aproveitamento>=80?'green':t.aproveitamento>=50?'amber':'red'}">${t.aproveitamento}%</span></td>
      <td class="r"><span class="badge ${t.pct_qualidade>=80?'green':t.pct_qualidade>=50?'amber':'red'}">${t.pct_qualidade}%</span></td>
      <td class="r"><span class="badge ${t.pct_meta>=100?'green':t.pct_meta>=60?'amber':'red'}">${t.pct_meta}%</span></td>
      <td class="r" style="color:var(--muted);font-size:10px">${t.os_perfeitas}/${t.total_os}</td>
    </tr>
  `).join('')
}

function loadRankingOntem(btn){
  const ontem=new Date(Date.now()-86400000).toISOString().split('T')[0]
  loadRanking(ontem,btn)
}

async function loadProdAssunto(){
  const d=await apiFetch(`${SAIS}/produtividade/por-assunto`)
  const el=document.getElementById('prod-assunto-content')
  if(!d.por_assunto?.length){el.innerHTML=`<div class="empty"><div class="empty-icon">📊</div>Sem dados</div>`;return}
  el.innerHTML=`<div class="card"><div class="tbl-wrap"><table>
    <thead><tr><th>Assunto</th><th>Categoria</th><th class="r">Total</th><th class="r">Finalizadas</th><th class="r">Tempo Médio</th></tr></thead>
    <tbody>${d.por_assunto.map(r=>`
      <tr>
        <td><strong>${r.assunto||'—'}</strong></td>
        <td><span class="badge" style="background:rgba(0,0,0,.2);color:${catCor(r.categoria)}">${r.categoria||'—'}</span></td>
        <td class="r">${r.total}</td>
        <td class="r" style="color:var(--green)">${r.finalizadas||0}</td>
        <td class="r">${r.minutos_medio?r.minutos_medio+'min':'—'}</td>
      </tr>
    `).join('')}</tbody>
  </table></div></div>`
}

// ═══════════════════════════════════════════════════
// AUDITORIA
// ═══════════════════════════════════════════════════
async function loadAuditoria(){
  const [resumo,ocorrs]=await Promise.all([
    apiFetch(`${SAIS}/auditoria/resumo`),
    apiFetch(`${SAIS}/auditoria/ocorrencias?limit=30`),
  ])
  const t=resumo.totais||{}
  document.getElementById('audit-kpis').innerHTML=`
    <div class="kpi" style="--ac:var(--red)"><div class="kpi-lbl">Críticas</div><div class="kpi-val">${t.criticas||0}</div></div>
    <div class="kpi" style="--ac:var(--amber)"><div class="kpi-lbl">Altas</div><div class="kpi-val">${t.altas||0}</div></div>
    <div class="kpi" style="--ac:var(--cyan)"><div class="kpi-lbl">Médias</div><div class="kpi-val">${t.medias||0}</div></div>
    <div class="kpi" style="--ac:var(--green)"><div class="kpi-lbl">Resolvidas</div><div class="kpi-val">${t.resolvidas||0}</div></div>
  `
  renderOcorrencias(ocorrs.ocorrencias||[])
}

async function loadAuditoriaTipo(tipo){
  const d=await apiFetch(`${SAIS}/auditoria/ocorrencias?tipo=${tipo}&limit=30`)
  document.getElementById('audit-kpis').innerHTML=''
  renderOcorrencias(d.ocorrencias||[])
}

function renderOcorrencias(lista){
  const el=document.getElementById('audit-content')
  if(!lista.length){el.innerHTML=`<div class="empty"><div class="empty-icon">✅</div>Nenhuma ocorrência encontrada</div>`;return}
  el.innerHTML=lista.map(a=>`
    <div class="critico-card ${criticidadeCls(a.criticidade)}" onclick="abrirModalAuditoria(${a.id})">
      <div class="critico-icon">${a.criticidade==='critica'?'🚨':a.criticidade==='alta'?'⚠️':'🔍'}</div>
      <div class="critico-info">
        <div class="critico-titulo">${a.subtipo} — ${a.tecnico_nome||'—'} ${a.os_id?'· OS #'+a.os_id:''}</div>
        <div class="critico-sub">${a.descricao||''}</div>
      </div>
      <span class="badge ${criticidadeCls(a.criticidade)}">${a.criticidade}</span>
    </div>
  `).join('')
}

// ═══════════════════════════════════════════════════
// TÉCNICOS
// ═══════════════════════════════════════════════════
async function loadTecnicos(){
  const [ranking,tecs]=await Promise.all([
    apiFetch(`${SAIS}/produtividade/ranking`),
    apiFetch('/api/tecnicos/'),
  ])
  const rankMap={}
  ;(ranking.ranking||[]).forEach(t=>{rankMap[t.tecnico_id]=t})
  document.getElementById('tec-cards').innerHTML=(tecs||[]).map(t=>{
    const r=rankMap[t.id]||{}
    const pct=r.pct_meta||0
    const cor=pct>=80?'var(--green)':pct>=50?'var(--amber)':'var(--red)'
    return `
      <div class="card" style="cursor:pointer" onclick="abrirModalTecnico(${t.id},'${esc(t.nome)}')">
        <div style="font-size:13px;font-weight:800;margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${t.nome}</div>
        <div style="font-size:9px;color:var(--muted);margin-bottom:10px">ID IXC: ${t.ixc_funcionario_id} · Meta: ${t.meta_dia} OS/dia</div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px">
          <div style="background:var(--s2);border-radius:6px;padding:7px;text-align:center">
            <div style="font-size:14px;font-weight:800;font-family:'DM Mono',monospace;color:var(--green)">${r.total_os||0}</div>
            <div style="font-size:8px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-top:1px">OS</div>
          </div>
          <div style="background:var(--s2);border-radius:6px;padding:7px;text-align:center">
            <div style="font-size:14px;font-weight:800;font-family:'DM Mono',monospace;color:${cor}">${pct}%</div>
            <div style="font-size:8px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-top:1px">Meta</div>
          </div>
          <div style="background:var(--s2);border-radius:6px;padding:7px;text-align:center">
            <div style="font-size:14px;font-weight:800;font-family:'DM Mono',monospace;color:var(--cyan)">${r.score||0}</div>
            <div style="font-size:8px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-top:1px">Score</div>
          </div>
        </div>
      </div>
    `
  }).join('')
}

// ═══════════════════════════════════════════════════
// AUTOMAÇÕES LOGS
// ═══════════════════════════════════════════════════
async function loadAutoLogs(){
  // Usa tabela sais_automacoes_log diretamente via endpoint genérico
  const el=document.getElementById('auto-logs-content')
  try{
    const d=await apiFetch('/api/sais/auditoria/ocorrencias?limit=1') // teste
    el.innerHTML=`<div class="empty"><div class="empty-icon">🤖</div>Endpoint de logs em desenvolvimento — verifique /var/log/sais_auditoria.log no servidor</div>`
  }catch(e){
    el.innerHTML=`<div class="empty"><div class="empty-icon">⚠️</div>Erro ao carregar logs</div>`
  }
}

// ═══════════════════════════════════════════════════
// ADMIN
// ═══════════════════════════════════════════════════
async function loadUsuarios(){
  const d=await apiFetch('/api/admin/usuarios/')
  document.getElementById('usr-table').innerHTML=(d||[]).map(u=>`
    <tr>
      <td style="font-family:'DM Mono',monospace;color:var(--cyan)">${u.login}</td>
      <td><strong>${u.nome}</strong></td>
      <td class="r"><span class="badge cyan">${nivelLabel(u.nivel)}</span></td>
      <td class="r"><span class="badge ${u.ativo?'green':'red'}">${u.ativo?'Ativo':'Inativo'}</span></td>
    </tr>
  `).join('')
}

async function loadPermissoes(){
  const d=await apiFetch('/api/admin/permissoes/')
  const mods=[...new Set((d||[]).map(r=>r.modulo))]
  document.getElementById('perm-table').innerHTML=mods.map(mod=>{
    const niveis=[1,2,3,4].map(n=>{
      const row=(d||[]).find(r=>r.modulo===mod&&r.nivel===n)
      return `<td class="r"><span class="badge ${row?.permitido?'green':'muted'}">${row?.permitido?'✓':'—'}</span></td>`
    }).join('')
    return `<tr><td><strong>${mod}</strong></td>${niveis}</tr>`
  }).join('')
}

// ═══════════════════════════════════════════════════
// MODAL OS
// ═══════════════════════════════════════════════════
async function abrirModalOS(osId){
  document.getElementById('modal-os-title').textContent=`OS #${osId}`
  document.getElementById('modal-os-sub').textContent='Carregando...'
  // Reset tabs
  switchTab('os','resumo',document.querySelector('#modal-os .modal-tab'))
  document.getElementById('os-tab-resumo').innerHTML=`<div class="loading"><div class="spinner"></div>Carregando...</div>`
  abrirModal('modal-os')

  try{
    const [d, pont]=await Promise.all([
      apiFetch(`${SAIS}/visao-geral/os/${osId}`),
      apiFetch(`${SAIS}/pontuacao/os/${osId}`)
    ])
    const os=d.os||{}
    const sla=d.sla||{}
    const audits=d.auditorias||[]

    document.getElementById('modal-os-sub').textContent=
      `${os.tecnico_nome||'—'} · ${os.nome_assunto||os.categoria||'—'} · ${statusLabel(os.status)}`

    // Tab Resumo
    document.getElementById('os-tab-resumo').innerHTML=`
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px">
        <div>
          <div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px">Informações</div>
          <div style="display:flex;flex-direction:column;gap:6px">
            ${infoRow('Técnico', os.tecnico_nome||'—')}
            ${infoRow('Assunto', os.nome_assunto||'—')}
            ${infoRow('Categoria', os.categoria||'—')}
            ${infoRow('Status', `<span class="badge ${statusCls(os.status)}">${statusLabel(os.status)}</span>`)}
          </div>
        </div>
        <div>
          <div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px">Datas</div>
          <div style="display:flex;flex-direction:column;gap:6px">
            ${infoRow('Abertura', fmtData(os.data_abertura))}
            ${infoRow('Agenda', fmtData(os.data_agenda)||'—')}
            ${infoRow('Fechamento', fmtData(os.data_fechamento)||'—')}
          </div>
        </div>
      </div>
    `

    // Tab SLA
    const slaColor=sla.status_sla==='no_prazo'?'var(--green)':sla.status_sla==='em_risco'?'var(--amber)':'var(--red)'
    const slaPct=Math.min(sla.percentual_consumido||0,100)
    document.getElementById('os-tab-sla').innerHTML=`
      <div class="modal-stat" style="flex-direction:column;text-align:left;padding:0;border:none;margin-bottom:14px">
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px">
          ${statBox('Previsto', (sla.horas_previstas||0)+'h', 'var(--cyan)')}
          ${statBox('Realizado', sla.horas_realizadas!=null?sla.horas_realizadas+'h':'—', slaColor)}
          ${statBox('Status', sla.status_sla||'—', slaColor)}
        </div>
        <div style="font-size:10px;color:var(--muted);margin-bottom:6px">Consumo do SLA: ${slaPct}%</div>
        <div class="sla-bar"><div class="sla-bar-fill" style="width:${slaPct}%;background:${slaColor}"></div></div>
        ${sla.abaixo_minimo?`<div style="margin-top:8px;font-size:11px;color:var(--amber)">⚠️ Tempo abaixo do mínimo esperado</div>`:''}
        ${sla.acima_maximo?`<div style="margin-top:8px;font-size:11px;color:var(--red)">🚨 Tempo acima do máximo esperado</div>`:''}
      </div>
    `

    // Tab Auditoria
    document.getElementById('os-tab-auditoria').innerHTML=audits.length
      ?audits.map(a=>`
        <div class="critico-card ${criticidadeCls(a.criticidade)}" style="margin-bottom:8px">
          <div class="critico-icon">${a.criticidade==='critica'?'🚨':'⚠️'}</div>
          <div class="critico-info">
            <div class="critico-titulo">${a.subtipo}</div>
            <div class="critico-sub">${a.descricao||''}</div>
            <div style="font-size:9px;color:var(--muted);margin-top:3px">Detectado: ${fmtData(a.criado_em)}</div>
          </div>
          <span class="badge ${criticidadeCls(a.criticidade)}">${a.criticidade}</span>
        </div>
      `).join('')
      :`<div class="empty"><div class="empty-icon">✅</div>Nenhuma ocorrência de auditoria</div>`

    // Tab Pontuação
    if(pont.calculado){
      const det=pont.detalhes||{}
      const ev=pont.evidencias||{}
      const pends=pont.pendencias||[]
      const pct=pont.pontos_base>0?Math.round(pont.pontos_final/pont.pontos_base*100):0
      const pctCor=pct>=80?'var(--green)':pct>=50?'var(--amber)':'var(--red)'
      document.getElementById('os-tab-pontuacao').innerHTML=`
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px">
          ${statBox('Pontos Base', pont.pontos_base, 'var(--muted)')}
          ${statBox('Pontos Finais', pont.pontos_final, pctCor)}
          ${statBox('Aproveitamento', pct+'%', pctCor)}
        </div>

        <div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px">Penalidades & Bônus</div>
        <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:14px">
          ${det.pen_foto<0?`${infoRow('📷 Sem foto', '<span style="color:var(--red)">'+det.pen_foto+' pts</span>')}`:''}
          ${det.pen_app<0?`${infoRow('📱 Sem app/deslocamento', '<span style="color:var(--red)">'+det.pen_app+' pts</span>')}`:''}
          ${det.pen_produto<0?`${infoRow('📦 Sem produto/comodato', '<span style="color:var(--red)">'+det.pen_produto+' pts</span>')}`:''}
          ${det.pen_descricao<0?`${infoRow('📝 Descrição curta', '<span style="color:var(--red)">'+det.pen_descricao+' pts</span>')}`:''}
          ${det.bonus_tempo>0?`${infoRow('⏱️ Bônus tempo', '<span style="color:var(--green)">+'+det.bonus_tempo+' pts</span>')}`:''}
          ${det.bonus_tempo<0?`${infoRow('⏱️ Pen. tempo', '<span style="color:var(--red)">'+det.bonus_tempo+' pts</span>')}`:''}
          ${det.bonus_fibra>0?`${infoRow('🔌 Bônus fibra', '<span style="color:var(--green)">+'+det.bonus_fibra+' pts</span>')}`:''}
          ${det.pen_foto===0&&det.pen_app===0&&det.pen_produto===0&&det.pen_descricao===0&&det.bonus_tempo===0&&det.bonus_fibra===0?'<div style="color:var(--green);font-size:11px;padding:4px 0">✅ Nenhuma penalidade</div>':''}
        </div>

        <div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px">Evidências</div>
        <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:14px">
          ${infoRow('Fotos', ev.total_fotos)}
          ${infoRow('Usou App', ev.tem_app?'<span class="badge green">Sim</span>':'<span class="badge red">Não</span>')}
          ${infoRow('Produto registrado', ev.tem_produto?'<span class="badge green">Sim</span>':'<span class="badge red">Não</span>')}
          ${ev.metros_fibra>0?infoRow('Fibra passada', ev.metros_fibra+'m'):''}
          ${ev.minutos_exec>0?infoRow('Tempo execução', Math.round(ev.minutos_exec)+'min'):''}
          ${infoRow('Tam. descrição', ev.len_descricao+' chars')}
          ${infoRow('Aprovada', pont.aprovada?'<span class="badge green">Sim</span>':'<span class="badge amber">Pendente</span>')}
        </div>

        ${pends.length?`
          <div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px">Pendências</div>
          <div style="display:flex;flex-wrap:wrap;gap:6px">
            ${pends.map(p=>`<span class="badge red">${p}</span>`).join('')}
          </div>
        `:''}

        <div style="font-size:9px;color:var(--muted);margin-top:12px">Calculado em: ${fmtData(pont.calculado_em)}</div>
      `
    } else {
      document.getElementById('os-tab-pontuacao').innerHTML=`
        <div class="empty">
          <div class="empty-icon">⏳</div>
          ${pont.mensagem||'Pontuação não calculada. Aguarde o próximo ciclo (15 min).'}
        </div>
      `
    }

    // Tab Histórico
    document.getElementById('os-tab-historico').innerHTML=`
      <div style="font-size:11px;color:var(--muted);padding:8px 0">
        <div>${infoRow('OS ID', os.ixc_os_id)}</div>
        <div>${infoRow('Assunto ID', os.ixc_assunto_id)}</div>
        <div>${infoRow('Técnico ID', os.tecnico_id)}</div>
        <div>${infoRow('Sincronizado', fmtData(os.sincronizado_em))}</div>
      </div>
    `
  }catch(e){
    document.getElementById('os-tab-resumo').innerHTML=`<div class="empty"><div class="empty-icon">⚠️</div>Erro ao carregar OS</div>`
  }
}

function infoRow(label,value){
  return `<div style="display:flex;justify-content:space-between;align-items:center;font-size:11px;padding:4px 0;border-bottom:1px solid rgba(255,255,255,.03)">
    <span style="color:var(--muted)">${label}</span>
    <span style="font-weight:600">${value}</span>
  </div>`
}
function statBox(label,value,cor){
  return `<div style="background:var(--s2);border-radius:8px;padding:12px;text-align:center">
    <div style="font-size:18px;font-weight:800;font-family:'DM Mono',monospace;color:${cor}">${value}</div>
    <div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-top:3px">${label}</div>
  </div>`
}

// ═══════════════════════════════════════════════════
// MODAL TÉCNICO
// ═══════════════════════════════════════════════════
async function abrirModalTecnico(tecId,tecNome){
  document.getElementById('modal-tec-title').textContent=tecNome||'Técnico'
  document.getElementById('modal-tec-sub').textContent='Carregando...'
  document.getElementById('modal-tec-stats').innerHTML=''
  switchTab('tec','hoje',document.querySelector('#modal-tec .modal-tab'))
  document.getElementById('tec-tab-hoje').innerHTML=`<div class="loading"><div class="spinner"></div>Carregando...</div>`
  abrirModal('modal-tec')

  try{
    const d=await apiFetch(`${SAIS}/visao-geral/tecnico/${tecId}`)
    const t=d.tecnico||{}
    const hoje=d.hoje||{}
    const score=d.score||{}

    document.getElementById('modal-tec-sub').textContent=
      `ID IXC: ${t.ixc_funcionario_id||'—'} · Meta: ${t.meta_dia||8} OS/dia`

    // Stats header
    document.getElementById('modal-tec-stats').innerHTML=`
      <div class="modal-stat"><div class="modal-stat-val">${hoje.total||0}</div><div class="modal-stat-lbl">Total OS</div></div>
      <div class="modal-stat"><div class="modal-stat-val" style="color:var(--green)">${hoje.finalizadas||0}</div><div class="modal-stat-lbl">Finalizadas</div></div>
      <div class="modal-stat"><div class="modal-stat-val" style="color:var(--amber)">${hoje.em_campo||0}</div><div class="modal-stat-lbl">Em Campo</div></div>
      <div class="modal-stat"><div class="modal-stat-val" style="color:var(--cyan)">${score.score_final||0}</div><div class="modal-stat-lbl">Score</div></div>
      <div class="modal-stat"><div class="modal-stat-val" style="color:${score.pct_meta>=80?'var(--green)':score.pct_meta>=50?'var(--amber)':'var(--red)'}">${score.pct_meta||0}%</div><div class="modal-stat-lbl">Meta</div></div>
    `

    // Tab Hoje
    document.getElementById('tec-tab-hoje').innerHTML=`
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px">
        ${statBox('Finalizadas', hoje.finalizadas||0, 'var(--green)')}
        ${statBox('Em Campo', hoje.em_campo||0, 'var(--amber)')}
        ${statBox('Agendadas', hoje.agendadas||0, 'var(--cyan)')}
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px">
        ${Object.entries(score.por_categoria||{}).map(([cat,v])=>{
          const total = typeof v === 'object' ? (v.os||v.pontos||0) : v
          return `<div style="background:var(--s2);border-radius:6px;padding:8px;text-align:center">
            <div style="font-size:16px;font-weight:800;color:${catCor(cat)}">${total}</div>
            <div style="font-size:9px;color:var(--muted);text-transform:capitalize">${cat}</div>
          </div>`
        }).join('')}
      </div>
    `

    // Tab Agenda
    document.getElementById('tec-tab-agenda').innerHTML=(d.agenda||[]).length
      ?d.agenda.map(o=>`
        <div class="agenda-os-item" onclick="abrirModalOS(${o.ixc_os_id})">
          <span class="agenda-hora">${fmtHora(o.data_agenda)}</span>
          <span class="agenda-os-id">#${o.ixc_os_id}</span>
          <span class="agenda-os-nome">${o.assunto||'—'}</span>
        </div>
      `).join('')
      :`<div class="empty"><div class="empty-icon">📅</div>Nenhuma OS agendada</div>`

    // Tab Produtividade
    const hist=d.historico_7d||[]
    document.getElementById('tec-tab-produtividade').innerHTML=`
      <div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px">Histórico 7 dias</div>
      <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:6px">
        ${hist.map(h=>`
          <div style="background:var(--s2);border-radius:6px;padding:8px 4px;text-align:center">
            <div style="font-size:14px;font-weight:800;color:var(--cyan)">${h.total_os}</div>
            <div style="font-size:8px;color:var(--muted)">${h.data.slice(5)}</div>
            <div style="font-size:9px;color:${h.eficiencia>=80?'var(--green)':'var(--amber)'}">${h.eficiencia}%</div>
          </div>
        `).join('')}
      </div>
    `

    // Tab Auditoria
    document.getElementById('tec-tab-auditoria').innerHTML=(d.auditorias||[]).length
      ?d.auditorias.map(a=>`
        <div class="critico-card ${criticidadeCls(a.criticidade)}" style="margin-bottom:7px">
          <div class="critico-icon">🔍</div>
          <div class="critico-info">
            <div class="critico-titulo">${a.subtipo} ${a.os_id?'· OS #'+a.os_id:''}</div>
            <div class="critico-sub">${a.descricao||''}</div>
          </div>
          <span class="badge ${criticidadeCls(a.criticidade)}">${a.criticidade}</span>
        </div>
      `).join('')
      :`<div class="empty"><div class="empty-icon">✅</div>Sem ocorrências de auditoria</div>`

    // Tab OS Recentes
    document.getElementById('tec-tab-os-recentes').innerHTML=(d.os_recentes||[]).length
      ?d.os_recentes.map(o=>`
        <div class="os-row" onclick="abrirModalOS(${o.ixc_os_id})">
          <div class="os-id">#${o.ixc_os_id}</div>
          <div class="os-info">
            <div class="os-assunto">${o.assunto||'—'}</div>
            <div class="os-meta"><span>${fmtData(o.data_fechamento||o.data_agenda||o.data_abertura)}</span></div>
          </div>
          <span class="os-status-chip ${statusCls(o.status)}">${statusLabel(o.status)}</span>
        </div>
      `).join('')
      :`<div class="empty"><div class="empty-icon">📋</div>Nenhuma OS recente</div>`

  }catch(e){
    document.getElementById('tec-tab-hoje').innerHTML=`<div class="empty"><div class="empty-icon">⚠️</div>Erro ao carregar técnico</div>`
  }
}

// Modal auditoria simples
function abrirModalAuditoria(id){
  // Abre modal de OS se tiver os_id, senão alerta
  alert(`Auditoria #${id} — detalhamento completo em breve`)
}

// ═══════════════════════════════════════════════════
// MODAL UTILS
// ═══════════════════════════════════════════════════
function abrirModal(id){document.getElementById(id).classList.add('active')}
function fecharModal(id){document.getElementById(id).classList.remove('active')}
function overlayClick(e,id){if(e.target===e.currentTarget)fecharModal(id)}
document.addEventListener('keydown',e=>{
  if(e.key!=='Escape') return
  const abertos=[...document.querySelectorAll('.modal-overlay.active')]
  if(abertos.length) fecharModal(abertos[abertos.length-1].id)
})

function switchTab(modalId, tabId, el){
  // Desativar todas as tabs e conteúdos
  const modal=document.getElementById('modal-'+modalId)
  modal.querySelectorAll('.modal-tab').forEach(t=>t.classList.remove('active'))
  modal.querySelectorAll('.modal-tab-content').forEach(t=>t.classList.remove('active'))
  // Ativar a tab clicada
  if(el) el.classList.add('active')
  const content=document.getElementById(`${modalId}-tab-${tabId}`)
  if(content) content.classList.add('active')
}

// ═══════════════════════════════════════════════════
// MODO TV
// ═══════════════════════════════════════════════════
let tvInterval=null

async function abrirTV(){
  document.getElementById('tv-overlay').classList.add('active')
  iniciarRelogioTV()
  await loadTV()
  tvInterval=setInterval(loadTV,30000)
  // Buscar popups pendentes
  setInterval(loadTVPopups,10000)
}

function fecharTV(){
  document.getElementById('tv-overlay').classList.remove('active')
  if(tvInterval) clearInterval(tvInterval)
}

function iniciarRelogioTV(){
  const tick=()=>{
    const now=new Date()
    document.getElementById('tv-clock').textContent=now.toLocaleTimeString('pt-BR')
    document.getElementById('tv-date').textContent=now.toLocaleDateString('pt-BR',{weekday:'long',day:'2-digit',month:'long'})
  }
  tick()
  setInterval(tick,1000)
}

async function loadTV(){
  try{
    const d=await apiFetch(`${SAIS}/tv/estado`)
    const k=d.kpis||{}

    // KPIs
    document.getElementById('tv-kpis').innerHTML=`
      <div class="tv-kpi" style="--ac:var(--cyan)">
        <div class="tv-kpi-val">${k.total||0}</div><div class="tv-kpi-lbl">Total OS</div>
      </div>
      <div class="tv-kpi" style="--ac:var(--green)">
        <div class="tv-kpi-val">${k.finalizadas||0}</div><div class="tv-kpi-lbl">Finalizadas</div>
      </div>
      <div class="tv-kpi" style="--ac:var(--orange)">
        <div class="tv-kpi-val">${k.pct_meta||0}%</div><div class="tv-kpi-lbl">Meta ${k.meta||150}</div>
      </div>
    `

    // Ranking
    document.getElementById('tv-ranking').innerHTML=(d.top5||[]).map((t,i)=>`
      <div class="tv-ranking-item">
        <div class="tv-rank-pos rpos ${rposCls(i)}">${i+1}</div>
        <div class="tv-rank-nome">${t.nome}</div>
        <div class="tv-rank-os">${t.total_os}</div>
        <span class="badge ${t.pct_meta>=80?'green':t.pct_meta>=50?'amber':'red'}">${t.pct_meta}%</span>
      </div>
    `).join('')||`<div style="color:var(--muted);font-size:11px;padding:8px">Nenhum dado</div>`

    // Recentes
    document.getElementById('tv-recentes').innerHTML=(d.recentes||[]).map(o=>`
      <div class="tv-recent-item">
        <span class="tv-recent-id">#${o.ixc_os_id}</span>
        <strong>${o.tecnico||'—'}</strong> · ${o.assunto?.slice(0,30)||'—'}
        <div style="font-size:10px;color:var(--muted)">${fmtHora(o.data_fechamento)}</div>
      </div>
    `).join('')||`<div style="color:var(--muted);font-size:11px;padding:8px">Nenhuma OS finalizada</div>`

    // Alertas
    document.getElementById('tv-alertas').innerHTML=(d.alertas||[]).map(a=>`
      <div style="padding:6px 0;border-bottom:1px solid rgba(255,255,255,.03);font-size:11px">
        <span style="color:${a.criticidade==='critico'?'var(--red)':'var(--amber)'}">${a.titulo}</span>
      </div>
    `).join('')||`<div style="color:var(--green);font-size:11px;padding:8px">✅ Sem alertas críticos</div>`

  }catch(e){console.error('tv:',e)}
}

async function loadTVPopups(){
  const d=await apiFetch(`${SAIS}/tv/popups-pendentes`)
  ;(d.popups||[]).forEach(p=>{
    mostrarPopupTV(p)
    fetch(`${SAIS}/tv/popups/${p.id}/exibido`,{method:'POST'})
  })
}

const POPUP_CFG={
  os_finalizada:{cor:'green',icone:'✅',dur:6000},
  sla_estourado:{cor:'red',icone:'🚨',dur:10000},
  sla_em_risco:{cor:'amber',icone:'⚠️',dur:8000},
  meta_atingida:{cor:'green',icone:'🏆',dur:8000},
  meta_em_risco:{cor:'amber',icone:'📉',dur:7000},
  tecnico_ocioso:{cor:'amber',icone:'💤',dur:7000},
  auditoria_grave:{cor:'red',icone:'🔍',dur:10000},
  os_atrasada:{cor:'red',icone:'⏰',dur:8000},
}

function mostrarPopupTV(dados){
  const cfg=POPUP_CFG[dados.tipo]||{cor:'amber',icone:'•',dur:6000}
  const el=document.createElement('div')
  el.className=`tv-popup ${cfg.cor}`
  el.innerHTML=`
    <div class="tv-popup-header">
      <span class="tv-popup-icon">${cfg.icone}</span>
      <span class="tv-popup-titulo">${dados.titulo||dados.tipo}</span>
    </div>
    <div class="tv-popup-sub">${dados.subtitulo||dados.mensagem||''}</div>
    <div class="tv-popup-bar"><div class="tv-popup-bar-fill ${cfg.cor}" style="width:100%;transition-duration:${cfg.dur}ms"></div></div>
  `
  document.getElementById('tv-popup-container').prepend(el)
  setTimeout(()=>el.style.transition='opacity .5s', 100)
  setTimeout(()=>el.style.opacity='0', cfg.dur-500)
  setTimeout(()=>el.remove(), cfg.dur)
  // Animar barra
  setTimeout(()=>{
    const bar=el.querySelector('.tv-popup-bar-fill')
    if(bar){bar.style.width='0%'}
  }, 200)
}

// ═══════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════
loadDashboard()
</script>
</body>
</html>
