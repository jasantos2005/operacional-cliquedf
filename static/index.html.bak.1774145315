<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>SAIS · HubProdutividade</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#07090c;--s1:#0d1117;--s2:#131920;--s3:#1c2333;--border:#1e2731;
  --text:#c9d4e0;--muted:#46586a;--sub:#2d3d50;
  --cyan:#00d4ff;--green:#00e5a0;--red:#ff4d6a;--amber:#ffb83f;--orange:#ff7849;--purple:#a78bfa;
  --sw:220px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--text);font-family:'Bricolage Grotesque',sans-serif;display:flex}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.02'/%3E%3C/svg%3E");pointer-events:none;z-index:9998}

/* ══ SIDEBAR ══════════════════════════════════════ */
.sb{width:var(--sw);background:var(--s1);border-right:1px solid var(--border);height:100vh;display:flex;flex-direction:column;flex-shrink:0;overflow:hidden}
.sb-top{flex:1;overflow-y:auto;padding:16px 12px 0}
.sb-brand{display:flex;align-items:center;gap:10px;margin-bottom:20px;padding:0 4px}
.sb-logo{width:34px;height:34px;background:linear-gradient(135deg,var(--cyan),#0060ff);border-radius:8px;display:grid;place-items:center;font-size:16px;flex-shrink:0;box-shadow:0 0 14px rgba(0,212,255,.2)}
.sb-title{font-size:13px;font-weight:800;letter-spacing:-.01em;line-height:1.2}
.sb-ver{font-size:9px;color:var(--muted);font-family:'DM Mono',monospace}

/* Menu grupos */
.sb-group{margin-bottom:4px}
.sb-group-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:7px 8px;border-radius:6px;cursor:pointer;
  font-size:11px;font-weight:700;color:var(--muted);
  text-transform:uppercase;letter-spacing:.08em;
  transition:all .15s;user-select:none;
  border:1px solid transparent;
}
.sb-group-header:hover{color:var(--text);background:rgba(255,255,255,.03)}
.sb-group-header.active{color:var(--cyan);background:rgba(0,212,255,.06);border-color:rgba(0,212,255,.12)}
.sb-group-header .ic{font-size:13px;margin-right:6px}
.sb-group-header .arrow{font-size:10px;transition:transform .2s;margin-left:auto}
.sb-group-header.open .arrow{transform:rotate(90deg)}

/* Submenus */
.sb-sub{display:none;padding-left:8px;margin-top:2px}
.sb-sub.open{display:block}
.sb-item{
  display:flex;align-items:center;gap:7px;
  padding:6px 8px;border-radius:6px;
  font-size:12px;font-weight:600;color:var(--muted);
  cursor:pointer;transition:all .15s;
  margin-bottom:1px;border:1px solid transparent;
}
.sb-item:hover{color:var(--text);background:rgba(255,255,255,.04)}
.sb-item.active{color:var(--cyan);background:rgba(0,212,255,.08);border-color:rgba(0,212,255,.12)}
.sb-item .dot{width:5px;height:5px;border-radius:50%;background:var(--border);flex-shrink:0}
.sb-item.active .dot{background:var(--cyan)}

.sb-footer{padding:12px;border-top:1px solid var(--border)}
.sb-user{display:flex;align-items:center;gap:8px}
.sb-av{width:26px;height:26px;border-radius:6px;background:var(--s2);border:1px solid var(--border);display:grid;place-items:center;font-size:11px;flex-shrink:0}
.sb-uname{font-size:11px;font-weight:700;line-height:1.2}
.sb-role{font-size:9px;color:var(--muted)}
.live{display:inline-block;width:5px;height:5px;border-radius:50%;background:var(--green);margin-right:3px;animation:blink 2s infinite}

/* ══ MAIN ══════════════════════════════════════════ */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{
  height:48px;background:var(--s1);border-bottom:1px solid var(--border);
  display:flex;align-items:center;padding:0 20px;gap:10px;flex-shrink:0;
}
.topbar-title{font-size:13px;font-weight:800}
.topbar-path{font-size:9px;color:var(--muted);font-family:'DM Mono',monospace}
.topbar-right{margin-left:auto;display:flex;align-items:center;gap:8px}
.date-chip{background:var(--s2);border:1px solid var(--border);border-radius:5px;padding:3px 9px;font-size:9px;font-family:'DM Mono',monospace;color:var(--muted)}
.ws-dot{width:8px;height:8px;border-radius:50%;background:var(--muted);transition:background .3s}
.ws-dot.connected{background:var(--green);box-shadow:0 0 6px rgba(0,229,160,.4)}
.btn-sync{background:rgba(0,212,255,.1);border:1px solid rgba(0,212,255,.2);color:var(--cyan);border-radius:5px;padding:4px 12px;font-size:10px;font-weight:700;cursor:pointer;transition:all .2s;font-family:'Bricolage Grotesque',sans-serif}
.btn-sync:hover{background:rgba(0,212,255,.18)}
.btn-tv{background:rgba(167,139,250,.1);border:1px solid rgba(167,139,250,.2);color:var(--purple);border-radius:5px;padding:4px 12px;font-size:10px;font-weight:700;cursor:pointer;transition:all .2s;font-family:'Bricolage Grotesque',sans-serif}
.btn-tv:hover{background:rgba(167,139,250,.18)}

/* Badges de alerta no topbar */
.badge-alert{background:var(--red);color:#fff;border-radius:10px;font-size:9px;font-weight:800;padding:1px 6px;font-family:'DM Mono',monospace;min-width:18px;text-align:center}

.content{flex:1;overflow-y:auto;padding:20px}
.page{display:none;animation:fadeUp .25s ease}
.page.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

/* ══ COMPONENTES COMUNS ═══════════════════════════ */
.pg-hd{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:16px}
.pg-title{font-size:20px;font-weight:800;letter-spacing:-.02em}
.pg-title span{color:var(--cyan)}
.pg-sub{font-size:11px;color:var(--muted);margin-top:2px}

.kpi-grid{display:grid;gap:10px;margin-bottom:16px}
.kpi-grid.c5{grid-template-columns:repeat(5,1fr)}
.kpi-grid.c4{grid-template-columns:repeat(4,1fr)}
.kpi-grid.c3{grid-template-columns:repeat(3,1fr)}
.kpi-grid.c2{grid-template-columns:repeat(2,1fr)}
.kpi{background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:14px;position:relative;overflow:hidden;transition:all .2s;cursor:pointer}
.kpi:hover{transform:translateY(-2px);border-color:rgba(255,255,255,.07)}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--ac,var(--cyan))}
.kpi-lbl{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.12em;font-weight:700;margin-bottom:7px}
.kpi-val{font-size:22px;font-weight:800;font-family:'DM Mono',monospace;color:var(--ac,var(--cyan));line-height:1}
.kpi-sub{font-size:9px;color:var(--muted);margin-top:4px}
.kpi-badge{position:absolute;top:12px;right:10px;font-size:9px;font-family:'DM Mono',monospace;padding:2px 6px;border-radius:4px}
.kpi-badge.up{background:rgba(0,229,160,.12);color:var(--green)}
.kpi-badge.dn{background:rgba(255,77,106,.12);color:var(--red)}

.card-grid{display:grid;gap:12px;margin-bottom:16px}
.card-grid.c2{grid-template-columns:1fr 1fr}
.card-grid.c3{grid-template-columns:1fr 1fr 1fr}
.card{background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:16px}
.card-head{font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin-bottom:14px;display:flex;align-items:center;gap:7px}
.card-head::after{content:'';flex:1;height:1px;background:var(--border)}

.badge{display:inline-block;padding:2px 7px;border-radius:4px;font-size:9px;font-weight:700;font-family:'DM Mono',monospace}
.badge.green{background:rgba(0,229,160,.1);color:var(--green)}
.badge.red{background:rgba(255,77,106,.1);color:var(--red)}
.badge.amber{background:rgba(255,184,63,.1);color:var(--amber)}
.badge.cyan{background:rgba(0,212,255,.08);color:var(--cyan)}
.badge.purple{background:rgba(167,139,250,.1);color:var(--purple)}
.badge.muted{background:var(--border);color:var(--muted)}

.alert-chips{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;min-height:28px}
.alert-chip{padding:4px 10px;border-radius:5px;font-size:10px;font-weight:700;border:1px solid;display:flex;align-items:center;gap:5px;cursor:pointer;transition:opacity .2s}
.alert-chip:hover{opacity:.8}
.alert-chip.red{background:rgba(255,77,106,.07);border-color:rgba(255,77,106,.22);color:var(--red)}
.alert-chip.amber{background:rgba(255,184,63,.07);border-color:rgba(255,184,63,.22);color:var(--amber)}
.alert-chip.green{background:rgba(0,229,160,.07);border-color:rgba(0,229,160,.22);color:var(--green)}

.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse}
thead th{font-size:9px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);padding:0 0 8px;text-align:left;border-bottom:1px solid var(--border);white-space:nowrap}
thead th.r{text-align:right}
tbody td{padding:8px 0;font-size:11px;border-bottom:1px solid rgba(255,255,255,.02);vertical-align:middle}
tbody td.r{text-align:right;font-family:'DM Mono',monospace;font-size:10px}
tbody tr:hover td{background:rgba(255,255,255,.015);cursor:pointer}

.rpos{display:inline-flex;width:20px;height:20px;align-items:center;justify-content:center;border-radius:5px;font-size:9px;font-weight:800;font-family:'DM Mono',monospace;margin-right:6px}
.rpos.p1{background:rgba(255,184,63,.15);color:var(--amber)}
.rpos.p2{background:rgba(0,212,255,.1);color:var(--cyan)}
.rpos.p3{background:rgba(0,229,160,.08);color:var(--green)}
.rpos.pn{background:var(--border);color:var(--muted)}

.bar-bg{background:var(--border);height:3px;border-radius:3px;margin-top:3px}
.bar-fill{height:3px;border-radius:3px;transition:width 1s cubic-bezier(.4,0,.2,1)}

.loading{display:flex;align-items:center;justify-content:center;padding:32px;color:var(--muted);font-size:11px;font-family:'DM Mono',monospace}
.spinner{width:14px;height:14px;border:2px solid var(--border);border-top-color:var(--cyan);border-radius:50%;animation:spin .7s linear infinite;margin-right:8px;flex-shrink:0}
.empty{text-align:center;padding:28px;color:var(--muted);font-size:11px}
.empty-icon{font-size:24px;margin-bottom:6px}

/* Lista de OS clicável */
.os-row{display:flex;align-items:center;padding:9px 12px;border-radius:8px;background:var(--s2);border:1px solid var(--border);margin-bottom:6px;cursor:pointer;transition:all .2s}
.os-row:hover{border-color:rgba(0,212,255,.25);transform:translateX(2px)}
.os-id{font-family:'DM Mono',monospace;font-size:11px;font-weight:700;color:var(--cyan);margin-right:10px;flex-shrink:0}
.os-info{flex:1;min-width:0}
.os-assunto{font-size:11px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.os-meta{font-size:10px;color:var(--muted);display:flex;gap:10px;margin-top:2px}
.os-status-chip{font-size:9px;padding:2px 7px;border-radius:4px;font-weight:700;text-transform:uppercase;font-family:'DM Mono',monospace;flex-shrink:0;margin-left:8px}
.os-status-chip.finalizada{background:rgba(0,229,160,.12);color:var(--green)}
.os-status-chip.agendada{background:rgba(0,212,255,.12);color:var(--cyan)}
.os-status-chip.aguardando{background:rgba(255,184,63,.12);color:var(--amber)}
.os-status-chip.execucao,.os-status-chip.aberta{background:rgba(167,139,250,.12);color:var(--purple)}

/* Técnico row */
.tec-row{display:flex;align-items:center;padding:8px 10px;border-radius:7px;background:var(--s2);border:1px solid var(--border);margin-bottom:5px;cursor:pointer;transition:all .2s}
.tec-row:hover{border-color:rgba(0,212,255,.25);transform:translateX(2px)}

/* ══ MODAIS ════════════════════════════════════════ */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.8);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;z-index:9000;padding:20px}
.modal-overlay.active{display:flex;animation:fadeIn .2s ease}
.modal{background:var(--s1);border:1px solid var(--border);border-radius:14px;width:100%;max-width:720px;max-height:85vh;overflow:hidden;display:flex;flex-direction:column;animation:slideUp .25s cubic-bezier(.4,0,.2,1);box-shadow:0 28px 70px rgba(0,0,0,.7)}
.modal.wide{max-width:900px}
.modal-header{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-shrink:0}
.modal-header-left{display:flex;flex-direction:column;gap:3px;min-width:0}
.modal-title{font-size:14px;font-weight:800}
.modal-sub{font-size:10px;color:var(--muted);font-family:'DM Mono',monospace}
.modal-close{background:var(--s2);border:1px solid var(--border);color:var(--muted);width:28px;height:28px;border-radius:7px;display:grid;place-items:center;cursor:pointer;font-size:16px;transition:all .2s;flex-shrink:0}
.modal-close:hover{border-color:var(--red);color:var(--red)}

/* Tabs dentro do modal */
.modal-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);padding:0 20px;flex-shrink:0}
.modal-tab{padding:10px 16px;font-size:11px;font-weight:700;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap}
.modal-tab:hover{color:var(--text)}
.modal-tab.active{color:var(--cyan);border-bottom-color:var(--cyan)}
.modal-tab-content{display:none;padding:16px 20px;overflow-y:auto;flex:1}
.modal-tab-content.active{display:block}

/* Stats do modal */
.modal-stats{display:flex;border-bottom:1px solid var(--border);flex-shrink:0}
.modal-stat{flex:1;padding:10px 14px;text-align:center;border-right:1px solid var(--border)}
.modal-stat:last-child{border-right:none}
.modal-stat-val{font-size:18px;font-weight:800;font-family:'DM Mono',monospace;color:var(--cyan);line-height:1}
.modal-stat-lbl{font-size:8px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-top:2px}

/* SLA bar */
.sla-bar{height:8px;background:var(--border);border-radius:4px;margin:8px 0;overflow:hidden}
.sla-bar-fill{height:8px;border-radius:4px;transition:width 1s ease}

/* ══ AGENDA ════════════════════════════════════════ */
.agenda-grid{display:flex;flex-direction:column;gap:10px}
.agenda-tec{background:var(--s2);border:1px solid var(--border);border-radius:10px;overflow:hidden}
.agenda-tec-header{display:flex;align-items:center;gap:8px;padding:10px 14px;background:var(--s3);border-bottom:1px solid var(--border);cursor:pointer}
.agenda-tec-nome{font-size:12px;font-weight:700;flex:1}
.agenda-tec-count{font-family:'DM Mono',monospace;font-size:11px;color:var(--cyan)}
.agenda-os{padding:8px 14px}
.agenda-os-item{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.03);cursor:pointer}
.agenda-os-item:last-child{border-bottom:none}
.agenda-os-item:hover .agenda-os-id{color:var(--cyan)}
.agenda-hora{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);width:50px;flex-shrink:0}
.agenda-os-id{font-family:'DM Mono',monospace;font-size:10px;font-weight:700;color:var(--sub);width:60px;flex-shrink:0;transition:color .2s}
.agenda-os-nome{font-size:11px;font-weight:600;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* ══ CENTRAL OPERACIONAL ═══════════════════════════ */
.critico-card{background:var(--s2);border:1px solid rgba(255,77,106,.2);border-radius:9px;padding:12px 14px;margin-bottom:8px;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:10px}
.critico-card:hover{border-color:rgba(255,77,106,.4);transform:translateX(2px)}
.critico-card.amber{border-color:rgba(255,184,63,.2)}
.critico-card.amber:hover{border-color:rgba(255,184,63,.4)}
.critico-icon{font-size:18px;flex-shrink:0}
.critico-info{flex:1;min-width:0}
.critico-titulo{font-size:12px;font-weight:700}
.critico-sub{font-size:10px;color:var(--muted);margin-top:2px}
.critico-badge{flex-shrink:0}

/* ══ MODO TV ════════════════════════════════════════ */
#tv-overlay{
  position:fixed;inset:0;background:var(--bg);z-index:9999;
  display:none;flex-direction:column;padding:24px;
  font-family:'Bricolage Grotesque',sans-serif;
}
#tv-overlay.active{display:flex}
.tv-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.tv-logo{font-size:18px;font-weight:800;color:var(--cyan)}
.tv-clock{font-family:'DM Mono',monospace;font-size:28px;font-weight:700;color:var(--text)}
.tv-date{font-size:12px;color:var(--muted);text-align:right}
.tv-body{display:grid;grid-template-columns:2fr 1fr;gap:20px;flex:1;overflow:hidden}
.tv-left{display:flex;flex-direction:column;gap:16px}
.tv-right{display:flex;flex-direction:column;gap:16px}
.tv-kpis{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.tv-kpi{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:16px;text-align:center;position:relative;overflow:hidden}
.tv-kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--ac,var(--cyan))}
.tv-kpi-val{font-size:36px;font-weight:800;font-family:'DM Mono',monospace;color:var(--ac,var(--cyan));line-height:1}
.tv-kpi-lbl{font-size:11px;color:var(--muted);margin-top:4px;text-transform:uppercase;letter-spacing:.1em}
.tv-section{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:14px;flex:1;overflow:hidden;display:flex;flex-direction:column}
.tv-section-title{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin-bottom:12px;display:flex;align-items:center;gap:7px}
.tv-section-title::after{content:'';flex:1;height:1px;background:var(--border)}
.tv-ranking-item{display:flex;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.03)}
.tv-ranking-item:last-child{border-bottom:none}
.tv-rank-pos{width:22px;height:22px;border-radius:5px;display:grid;place-items:center;font-size:10px;font-weight:800;font-family:'DM Mono',monospace;margin-right:8px;flex-shrink:0}
.tv-rank-nome{flex:1;font-size:13px;font-weight:700}
.tv-rank-os{font-family:'DM Mono',monospace;font-size:14px;font-weight:800;color:var(--cyan);margin-right:8px}
.tv-recent-item{padding:8px 0;border-bottom:1px solid rgba(255,255,255,.03);font-size:11px}
.tv-recent-item:last-child{border-bottom:none}
.tv-recent-id{font-family:'DM Mono',monospace;font-size:10px;color:var(--cyan);margin-right:6px}
.tv-btn-close{position:absolute;top:16px;right:16px;background:var(--s2);border:1px solid var(--border);color:var(--muted);padding:6px 14px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:700;font-family:'Bricolage Grotesque',sans-serif}
.tv-btn-close:hover{border-color:var(--red);color:var(--red)}

/* TV Popup */
#tv-popup-container{position:fixed;bottom:24px;right:24px;z-index:10000;display:flex;flex-direction:column;gap:10px;align-items:flex-end}
.tv-popup{
  background:var(--s1);border:1px solid var(--border);border-radius:12px;
  padding:14px 18px;min-width:280px;max-width:340px;
  box-shadow:0 8px 32px rgba(0,0,0,.5);
  animation:slideUp .3s ease;
}
.tv-popup.green{border-color:rgba(0,229,160,.3);box-shadow:0 8px 32px rgba(0,229,160,.1)}
.tv-popup.red{border-color:rgba(255,77,106,.3);box-shadow:0 8px 32px rgba(255,77,106,.1)}
.tv-popup.amber{border-color:rgba(255,184,63,.3);box-shadow:0 8px 32px rgba(255,184,63,.1)}
.tv-popup-header{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.tv-popup-icon{font-size:16px}
.tv-popup-titulo{font-size:12px;font-weight:800;flex:1}
.tv-popup-sub{font-size:10px;color:var(--muted)}
.tv-popup-bar{height:2px;background:rgba(255,255,255,.1);border-radius:1px;margin-top:8px;overflow:hidden}
.tv-popup-bar-fill{height:2px;border-radius:1px;transition:width linear}
.tv-popup-bar-fill.green{background:var(--green)}
.tv-popup-bar-fill.red{background:var(--red)}
.tv-popup-bar-fill.amber{background:var(--amber)}

/* Meta progress */
.meta-track{background:var(--border);border-radius:5px;height:6px;margin-top:8px;overflow:hidden}
.meta-fill{height:6px;border-radius:5px;transition:width 1.2s cubic-bezier(.4,0,.2,1)}

/* Tabs de período */
.period-tabs{display:flex;gap:4px;margin-bottom:12px}
.period-tab{padding:4px 12px;border-radius:5px;font-size:10px;font-weight:700;cursor:pointer;border:1px solid var(--border);color:var(--muted);background:transparent;transition:all .15s;font-family:'Bricolage Grotesque',sans-serif}
.period-tab.active{background:rgba(0,212,255,.1);border-color:rgba(0,212,255,.2);color:var(--cyan)}
.period-tab:hover:not(.active){color:var(--text)}

@media(max-width:1100px){.kpi-grid.c5{grid-template-columns:repeat(3,1fr)}.card-grid.c3{grid-template-columns:1fr 1fr}}
</style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sb">
  <div class="sb-top">
    <div class="sb-brand">
      <div class="sb-logo">📡</div>
      <div>
        <div class="sb-title">SAIS</div>
        <div class="sb-ver">CliqueDF · v2.0</div>
      </div>
    </div>

    <!-- 1. VISÃO GERAL -->
    <div class="sb-group">
      <div class="sb-group-header active open" onclick="toggleGroup(this,'visao-geral')">
        <span class="ic">📊</span> Visão Geral <span class="arrow">›</span>
      </div>
      <div class="sb-sub open" id="grp-visao-geral">
        <div class="sb-item active" onclick="nav('dashboard','visao-geral')"><span class="dot"></span> Dashboard do dia</div>
        <div class="sb-item" onclick="nav('eventos','visao-geral')"><span class="dot"></span> Eventos em tempo real</div>
        <div class="sb-item" onclick="nav('ultimas-os','visao-geral')"><span class="dot"></span> Últimas OS</div>
      </div>
    </div>

    <!-- 2. CENTRAL OPERACIONAL -->
    <div class="sb-group">
      <div class="sb-group-header" onclick="toggleGroup(this,'central')">
        <span class="ic">🔥</span> Central Operacional <span class="arrow">›</span>
      </div>
      <div class="sb-sub" id="grp-central">
        <div class="sb-item" onclick="nav('os-atrasadas','central')"><span class="dot"></span> OS Atrasadas</div>
        <div class="sb-item" onclick="nav('sla-risco','central')"><span class="dot"></span> Risco de SLA</div>
        <div class="sb-item" onclick="nav('tecnicos-ociosos','central')"><span class="dot"></span> Técnicos Ociosos</div>
        <div class="sb-item" onclick="nav('alertas','central')"><span class="dot"></span> Alertas <span id="badge-alertas" class="badge-alert" style="display:none">0</span></div>
      </div>
    </div>

    <!-- 3. AGENDA -->
    <div class="sb-group">
      <div class="sb-group-header" onclick="toggleGroup(this,'agenda')">
        <span class="ic">📅</span> Agenda Inteligente <span class="arrow">›</span>
      </div>
      <div class="sb-sub" id="grp-agenda">
        <div class="sb-item" onclick="nav('agenda-dia','agenda')"><span class="dot"></span> Agenda do dia</div>
        <div class="sb-item" onclick="nav('agenda-futura','agenda')"><span class="dot"></span> Agenda futura</div>
        <div class="sb-item" onclick="nav('reagendamentos','agenda')"><span class="dot"></span> Reagendamentos</div>
      </div>
    </div>

    <!-- 4. PRODUTIVIDADE -->
    <div class="sb-group">
      <div class="sb-group-header" onclick="toggleGroup(this,'produtividade')">
        <span class="ic">📈</span> Produtividade <span class="arrow">›</span>
      </div>
      <div class="sb-sub" id="grp-produtividade">
        <div class="sb-item" onclick="nav('ranking','produtividade')"><span class="dot"></span> Ranking Técnicos</div>
        <div class="sb-item" onclick="nav('prod-assunto','produtividade')"><span class="dot"></span> Por Tipo de OS</div>
        <div class="sb-item" onclick="nav('prod-eficiencia','produtividade')"><span class="dot"></span> Eficiência</div>
      </div>
    </div>

    <!-- 5. AUDITORIA -->
    <div class="sb-group">
      <div class="sb-group-header" onclick="toggleGroup(this,'auditoria')">
        <span class="ic">🧾</span> Auditoria <span class="arrow">›</span>
      </div>
      <div class="sb-sub" id="grp-auditoria">
        <div class="sb-item" onclick="nav('audit-exec','auditoria')"><span class="dot"></span> Execução</div>
        <div class="sb-item" onclick="nav('audit-tempo','auditoria')"><span class="dot"></span> Tempo</div>
        <div class="sb-item" onclick="nav('audit-sla','auditoria')"><span class="dot"></span> SLA</div>
        <div class="sb-item" onclick="nav('audit-comportamento','auditoria')"><span class="dot"></span> Comportamento</div>
      </div>
    </div>

    <!-- 6. INDICADORES -->
    <div class="sb-group">
      <div class="sb-group-header" onclick="toggleGroup(this,'indicadores')">
        <span class="ic">📉</span> Indicadores <span class="arrow">›</span>
      </div>
      <div class="sb-sub" id="grp-indicadores">
        <div class="sb-item" onclick="nav('ind-sla','indicadores')"><span class="dot"></span> SLA</div>
        <div class="sb-item" onclick="nav('ind-produtividade','indicadores')"><span class="dot"></span> Produtividade</div>
        <div class="sb-item" onclick="nav('ind-tendencias','indicadores')"><span class="dot"></span> Tendências</div>
      </div>
    </div>

    <!-- 7. TÉCNICOS -->
    <div class="sb-group">
      <div class="sb-group-header" onclick="toggleGroup(this,'tecnicos')">
        <span class="ic">👥</span> Técnicos <span class="arrow">›</span>
      </div>
      <div class="sb-sub" id="grp-tecnicos">
        <div class="sb-item" onclick="nav('tec-status','tecnicos')"><span class="dot"></span> Status atual</div>
        <div class="sb-item" onclick="nav('tec-performance','tecnicos')"><span class="dot"></span> Performance</div>
      </div>
    </div>

    <!-- 8. AUTOMAÇÕES -->
    <div class="sb-group">
      <div class="sb-group-header" onclick="toggleGroup(this,'automacoes')">
        <span class="ic">🤖</span> Automações <span class="arrow">›</span>
      </div>
      <div class="sb-sub" id="grp-automacoes">
        <div class="sb-item" onclick="nav('auto-logs','automacoes')"><span class="dot"></span> Logs de execução</div>
      </div>
    </div>

    <!-- 9. ADMIN -->
    <div class="sb-group">
      <div class="sb-group-header" onclick="toggleGroup(this,'admin')">
        <span class="ic">⚙️</span> Admin <span class="arrow">›</span>
      </div>
      <div class="sb-sub" id="grp-admin">
        <div class="sb-item" onclick="nav('usuarios','admin')"><span class="dot"></span> Usuários</div>
        <div class="sb-item" onclick="nav('permissoes','admin')"><span class="dot"></span> Permissões</div>
      </div>
    </div>
  </div>

  <div class="sb-footer">
    <div class="sb-user">
      <div class="sb-av">🛠️</div>
      <div>
        <div class="sb-uname">Ailton</div>
        <div class="sb-role"><span class="live"></span>Dev · Online</div>
      </div>
    </div>
  </div>
</aside>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div>
      <div class="topbar-title" id="tb-title">Dashboard do dia</div>
      <div class="topbar-path" id="tb-path">/visao-geral/dashboard</div>
    </div>
    <div class="topbar-right">
      <div class="ws-dot" id="ws-dot" title="WebSocket"></div>
      <div class="date-chip" id="date-chip"></div>
      <button class="btn-sync" onclick="syncAgora()">↻ Sync IXC</button>
      <button class="btn-tv" onclick="abrirTV()">📺 TV</button>
    </div>
  </div>

  <div class="content">

    <!-- ══ DASHBOARD DO DIA ══════════════════════ -->
    <div class="page active" id="page-dashboard">
      <div class="pg-hd">
        <div>
          <div class="pg-title">Visão <span>Operacional</span></div>
          <div class="pg-sub" id="db-sub">Carregando...</div>
        </div>
        <div id="db-status-pill" style="font-size:12px;font-weight:700;font-family:'DM Mono',monospace;background:var(--s2);border:1px solid var(--border);border-radius:20px;padding:5px 14px">⏳</div>
      </div>
      <div class="alert-chips" id="db-alertas"></div>
      <div class="kpi-grid c5" id="db-kpis"><div class="loading"><div class="spinner"></div>Carregando...</div></div>
      <div class="card-grid c2">
        <div class="card">
          <div class="card-head">📊 OS por Categoria</div>
          <div id="db-cats"></div>
        </div>
        <div class="card">
          <div class="card-head">🏆 Top Técnicos</div>
          <div id="db-top-tecs"><div class="loading"><div class="spinner"></div></div></div>
        </div>
      </div>
      <div class="card">
        <div class="card-head">🎯 Meta do Dia</div>
        <div id="db-meta"></div>
      </div>
    </div>

    <!-- ══ EVENTOS ══════════════════════════════ -->
    <div class="page" id="page-eventos">
      <div class="pg-hd"><div><div class="pg-title">Eventos <span>Tempo Real</span></div><div class="pg-sub">Atualizando via WebSocket</div></div></div>
      <div id="eventos-list"><div class="loading"><div class="spinner"></div>Aguardando eventos...</div></div>
    </div>

    <!-- ══ ÚLTIMAS OS ═══════════════════════════ -->
    <div class="page" id="page-ultimas-os">
      <div class="pg-hd"><div><div class="pg-title">Últimas <span>OS</span></div><div class="pg-sub">Ordens de serviço do dia</div></div></div>
      <div id="ultimas-os-list"><div class="loading"><div class="spinner"></div>Carregando...</div></div>
    </div>

    <!-- ══ OS ATRASADAS ═════════════════════════ -->
    <div class="page" id="page-os-atrasadas">
      <div class="pg-hd"><div><div class="pg-title">OS <span>Atrasadas</span></div><div class="pg-sub">Em campo há mais de 4 horas</div></div></div>
      <div id="os-atrasadas-list"><div class="loading"><div class="spinner"></div>Carregando...</div></div>
    </div>

    <!-- ══ SLA RISCO ════════════════════════════ -->
    <div class="page" id="page-sla-risco">
      <div class="pg-hd"><div><div class="pg-title">Risco de <span>SLA</span></div><div class="pg-sub">OS que podem estourar o prazo</div></div></div>
      <div id="sla-risco-content"><div class="loading"><div class="spinner"></div>Carregando...</div></div>
    </div>

    <!-- ══ TÉCNICOS OCIOSOS ══════════════════════ -->
    <div class="page" id="page-tecnicos-ociosos">
      <div class="pg-hd"><div><div class="pg-title">Técnicos <span>Ociosos</span></div><div class="pg-sub">Sem OS há mais de 1.5 horas</div></div></div>
      <div id="ociosos-list"><div class="loading"><div class="spinner"></div>Carregando...</div></div>
    </div>

    <!-- ══ ALERTAS ══════════════════════════════ -->
    <div class="page" id="page-alertas">
      <div class="pg-hd"><div><div class="pg-title">Central de <span>Alertas</span></div><div class="pg-sub">Todos os alertas do sistema</div></div></div>
      <div id="alertas-full-list"><div class="loading"><div class="spinner"></div>Carregando...</div></div>
    </div>

    <!-- ══ AGENDA DO DIA ════════════════════════ -->
    <div class="page" id="page-agenda-dia">
      <div class="pg-hd">
        <div><div class="pg-title">Agenda <span>do Dia</span></div><div class="pg-sub" id="agenda-dia-sub">Carregando...</div></div>
        <div class="period-tabs">
          <button class="period-tab active" onclick="loadAgendaDia(0,this)">Hoje</button>
          <button class="period-tab" onclick="loadAgendaDia(1,this)">Amanhã</button>
          <button class="period-tab" onclick="loadAgendaDia(2,this)">+2 dias</button>
        </div>
      </div>
      <div id="agenda-dia-content"><div class="loading"><div class="spinner"></div>Carregando...</div></div>
    </div>

    <!-- ══ AGENDA FUTURA ════════════════════════ -->
    <div class="page" id="page-agenda-futura">
      <div class="pg-hd"><div><div class="pg-title">Agenda <span>Futura</span></div><div class="pg-sub">Próximos 7 dias</div></div></div>
      <div id="agenda-futura-content"><div class="loading"><div class="spinner"></div>Carregando...</div></div>
    </div>

    <!-- ══ REAGENDAMENTOS ═══════════════════════ -->
    <div class="page" id="page-reagendamentos">
      <div class="pg-hd"><div><div class="pg-title">OS <span>Reagendadas</span></div><div class="pg-sub">Agendadas em datas passadas sem execução</div></div></div>
      <div id="reagendamentos-list"><div class="loading"><div class="spinner"></div>Carregando...</div></div>
    </div>

    <!-- ══ RANKING ══════════════════════════════ -->
    <div class="page" id="page-ranking">
      <div class="pg-hd">
        <div><div class="pg-title">Ranking <span>Técnicos</span></div><div class="pg-sub">Pontuação por regras · meta: 80 pts/dia</div></div>
        <div class="period-tabs">
          <button class="period-tab active" onclick="loadRanking(null,this)">Hoje</button>
          <button class="period-tab" onclick="loadRankingOntem(this)">Ontem</button>
        </div>
      </div>
      <div class="card">
        <div class="tbl-wrap">
          <table>
            <thead><tr><th>#</th><th>Técnico</th><th class="r">OS</th><th class="r">Pontos</th><th class="r">Aproveit.</th><th class="r">Qualidade</th><th class="r">Meta</th><th class="r">Perfeitas</th></tr></thead>
            <tbody id="ranking-table"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ══ PRODUTIVIDADE POR ASSUNTO ══════════════ -->
    <div class="page" id="page-prod-assunto">
      <div class="pg-hd"><div><div class="pg-title">Produtividade <span>por Tipo</span></div><div class="pg-sub">Distribuição de OS por assunto hoje</div></div></div>
      <div id="prod-assunto-content"><div class="loading"><div class="spinner"></div>Carregando...</div></div>
    </div>

    <!-- ══ AUDITORIA ════════════════════════════ -->
    <div class="page" id="page-audit-exec">
      <div class="pg-hd"><div><div class="pg-title">Auditoria <span>Operacional</span></div><div class="pg-sub">Ocorrências detectadas automaticamente</div></div></div>
      <div class="kpi-grid c4" id="audit-kpis"><div class="loading"><div class="spinner"></div></div></div>
      <div id="audit-content"><div class="loading"><div class="spinner"></div>Carregando...</div></div>
    </div>

    <!-- ══ TÉCNICOS STATUS ══════════════════════ -->
    <div class="page" id="page-tec-status">
      <div class="pg-hd"><div><div class="pg-title">Equipe <span>Técnica</span></div><div class="pg-sub">Status e desempenho em tempo real</div></div></div>
      <div class="card-grid c3" id="tec-cards"><div class="loading"><div class="spinner"></div>Carregando...</div></div>
    </div>

    <!-- ══ AUTOMAÇÕES LOGS ══════════════════════ -->
    <div class="page" id="page-auto-logs">
      <div class="pg-hd"><div><div class="pg-title">Logs de <span>Automações</span></div><div class="pg-sub">Histórico de execuções dos motores SAIS</div></div></div>
      <div id="auto-logs-content"><div class="loading"><div class="spinner"></div>Carregando...</div></div>
    </div>

    <!-- ══ USUÁRIOS ══════════════════════════════ -->
    <div class="page" id="page-usuarios">
      <div class="pg-hd"><div><div class="pg-title">Gestão de <span>Usuários</span></div><div class="pg-sub">Controle de acesso</div></div></div>
      <div class="card"><div class="tbl-wrap"><table><thead><tr><th>Login</th><th>Nome</th><th class="r">Nível</th><th class="r">Status</th></tr></thead><tbody id="usr-table"></tbody></table></div></div>
    </div>

    <!-- ══ PERMISSÕES ════════════════════════════ -->
    <div class="page" id="page-permissoes">
      <div class="pg-hd"><div><div class="pg-title">Gestão de <span>Permissões</span></div></div></div>
      <div class="card"><div class="tbl-wrap"><table><thead><tr><th>Módulo</th><th class="r">Op.</th><th class="r">Sup.</th><th class="r">Ger.</th><th class="r">Dir.</th></tr></thead><tbody id="perm-table"></tbody></table></div></div>
    </div>

  </div><!-- /content -->
</div><!-- /main -->

<!-- ══ MODAL OS ══════════════════════════════════════ -->
<div class="modal-overlay" id="modal-os" onclick="overlayClick(event,'modal-os')">
  <div class="modal wide">
    <div class="modal-header">
      <div class="modal-header-left">
        <div class="modal-title" id="modal-os-title">OS #—</div>
        <div class="modal-sub" id="modal-os-sub"></div>
      </div>
      <button class="modal-close" onclick="fecharModal('modal-os')">×</button>
    </div>
    <div class="modal-tabs">
      <div class="modal-tab active" onclick="switchTab('os','resumo',this)">Resumo</div>
      <div class="modal-tab" onclick="switchTab('os','sla',this)">SLA</div>
      <div class="modal-tab" onclick="switchTab('os','auditoria',this)">Auditoria</div>
      <div class="modal-tab" onclick="switchTab('os','pontuacao',this)">Pontuação</div>
      <div class="modal-tab" onclick="switchTab('os','historico',this)">Histórico</div>
    </div>
    <div id="os-tab-resumo"    class="modal-tab-content active"></div>
    <div id="os-tab-sla"       class="modal-tab-content"></div>
    <div id="os-tab-auditoria" class="modal-tab-content"></div>
    <div id="os-tab-pontuacao" class="modal-tab-content"></div>
    <div id="os-tab-historico" class="modal-tab-content"></div>
  </div>
</div>

<!-- ══ MODAL TÉCNICO ════════════════════════════════ -->
<div class="modal-overlay" id="modal-tec" onclick="overlayClick(event,'modal-tec')">
  <div class="modal wide">
    <div class="modal-header">
      <div class="modal-header-left">
        <div class="modal-title" id="modal-tec-title">Técnico</div>
        <div class="modal-sub" id="modal-tec-sub"></div>
      </div>
      <button class="modal-close" onclick="fecharModal('modal-tec')">×</button>
    </div>
    <div class="modal-stats" id="modal-tec-stats"></div>
    <div class="modal-tabs">
      <div class="modal-tab active" onclick="switchTab('tec','hoje',this)">Hoje</div>
      <div class="modal-tab" onclick="switchTab('tec','agenda',this)">Agenda</div>
      <div class="modal-tab" onclick="switchTab('tec','produtividade',this)">Produtividade</div>
      <div class="modal-tab" onclick="switchTab('tec','auditoria',this)">Auditoria</div>
      <div class="modal-tab" onclick="switchTab('tec','os-recentes',this)">OS Recentes</div>
    </div>
    <div id="tec-tab-hoje"        class="modal-tab-content active"></div>
    <div id="tec-tab-agenda"      class="modal-tab-content"></div>
    <div id="tec-tab-produtividade" class="modal-tab-content"></div>
    <div id="tec-tab-auditoria"   class="modal-tab-content"></div>
    <div id="tec-tab-os-recentes" class="modal-tab-content"></div>
  </div>
</div>

<!-- ══ MODO TV ══════════════════════════════════════ -->
<div id="tv-overlay">
  <button class="tv-btn-close" onclick="fecharTV()">✕ Fechar TV</button>
  <div class="tv-header">
    <div class="tv-logo">📡 SAIS · CliqueDF</div>
    <div style="text-align:right">
      <div class="tv-clock" id="tv-clock">--:--:--</div>
      <div class="tv-date" id="tv-date"></div>
    </div>
  </div>
  <div class="tv-body">
    <div class="tv-left">
      <div class="tv-kpis" id="tv-kpis"></div>
      <div class="tv-section" style="flex:none">
        <div class="tv-section-title">🏆 TOP TÉCNICOS</div>
        <div id="tv-ranking"></div>
      </div>
    </div>
    <div class="tv-right">
      <div class="tv-section">
        <div class="tv-section-title">⚡ ÚLTIMAS FINALIZAÇÕES</div>
        <div id="tv-recentes"></div>
      </div>
      <div class="tv-section" style="flex:none">
        <div class="tv-section-title">🚨 ALERTAS ATIVOS</div>
        <div id="tv-alertas"></div>
      </div>
    </div>
  </div>
</div>

<!-- TV Popup container -->
<div id="tv-popup-container"></div>

<script>
// ═══════════════════════════════════════════════════
// CONFIG
// ═══════════════════════════════════════════════════
const API    = '';
const SAIS   = '/api/sais';
const V2     = '/api/dashboard/v2';

const PAGES_CFG = {
  'dashboard':         {title:'Dashboard do dia',      path:'/visao-geral/dashboard',       load:loadDashboard},
  'eventos':           {title:'Eventos Tempo Real',     path:'/visao-geral/eventos',          load:loadEventos},
  'ultimas-os':        {title:'Últimas OS',             path:'/visao-geral/ultimas-os',       load:loadUltimasOS},
  'os-atrasadas':      {title:'OS Atrasadas',           path:'/central/os-atrasadas',         load:loadOsAtrasadas},
  'sla-risco':         {title:'Risco de SLA',           path:'/central/sla-risco',            load:loadSlaRisco},
  'tecnicos-ociosos':  {title:'Técnicos Ociosos',       path:'/central/tecnicos-ociosos',     load:loadOciosos},
  'alertas':           {title:'Central de Alertas',     path:'/central/alertas',              load:loadAlertasFull},
  'agenda-dia':        {title:'Agenda do Dia',          path:'/agenda/dia',                   load:()=>loadAgendaDia(0)},
  'agenda-futura':     {title:'Agenda Futura',          path:'/agenda/futura',                load:loadAgendaFutura},
  'reagendamentos':    {title:'Reagendamentos',         path:'/agenda/reagendamentos',        load:loadReagendamentos},
  'ranking':           {title:'Ranking Técnicos',       path:'/produtividade/ranking',        load:()=>loadRanking(null)},
  'prod-assunto':      {title:'Produtividade por Tipo', path:'/produtividade/por-assunto',    load:loadProdAssunto},
  'prod-eficiencia':   {title:'Eficiência',             path:'/produtividade/eficiencia',     load:loadProdAssunto},
  'audit-exec':        {title:'Auditoria Operacional',  path:'/auditoria/execucao',           load:loadAuditoria},
  'audit-tempo':       {title:'Auditoria de Tempo',     path:'/auditoria/tempo',              load:()=>loadAuditoriaTipo('tempo')},
  'audit-sla':         {title:'Auditoria de SLA',       path:'/auditoria/sla',                load:()=>loadAuditoriaTipo('sla')},
  'audit-comportamento':{title:'Auditoria Comportamento',path:'/auditoria/comportamento',    load:()=>loadAuditoriaTipo('comportamento')},
  'ind-sla':           {title:'Indicadores de SLA',     path:'/indicadores/sla',              load:loadDashboard},
  'ind-produtividade': {title:'Indicadores Produtividade',path:'/indicadores/produtividade',  load:()=>loadRanking(null)},
  'ind-tendencias':    {title:'Tendências',             path:'/indicadores/tendencias',       load:loadDashboard},
  'tec-status':        {title:'Status Técnicos',        path:'/tecnicos/status',              load:loadTecnicos},
  'tec-performance':   {title:'Performance Técnicos',   path:'/tecnicos/performance',         load:()=>loadRanking(null)},
  'auto-logs':         {title:'Logs Automações',        path:'/automacoes/logs',              load:loadAutoLogs},
  'usuarios':          {title:'Usuários',               path:'/admin/usuarios',               load:loadUsuarios},
  'permissoes':        {title:'Permissões',             path:'/admin/permissoes',             load:loadPermissoes},
};

// ═══════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════
async function apiFetch(url){const r=await fetch(url);return r.json()}
function fmtDate(d){if(!d)return'—';try{return new Date(d).toLocaleString('pt-BR',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'})}catch{return d}}
function fmtHora(d){if(!d)return'—';try{return new Date(d).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})}catch{return d}}
function rposCls(i){return['p1','p2','p3'][i]||'pn'}
function nivelLabel(n){return{1:'Operador',2:'Supervisor',3:'Gerente',4:'Diretoria',99:'Dev'}[n]||n}
function esc(s){return String(s||'').replace(/'/g,"\\'").replace(/"/g,'&quot;')}
function statusCls(s){return{finalizada:'finalizada',agendada:'agendada',aguardando:'aguardando',execucao:'execucao',aberta:'execucao'}[s]||'execucao'}
function statusLabel(s){return{finalizada:'Finalizada',agendada:'Agendada',aguardando:'Aguardando',execucao:'Em Campo',aberta:'Em Campo'}[s]||s||'—'}
function catCor(c){return{servico:'var(--cyan)',suporte:'var(--amber)',infra:'var(--purple)',retirada:'var(--orange)',outros:'var(--muted)'}[c]||'var(--muted)'}
function criticidadeCls(c){return{critica:'red',alta:'red',media:'amber',baixa:'muted'}[c]||'muted'}

// Date chip
document.getElementById('date-chip').textContent=new Date().toLocaleDateString('pt-BR',{weekday:'short',day:'2-digit',month:'short'})

// ═══════════════════════════════════════════════════
// NAVEGAÇÃO
// ═══════════════════════════════════════════════════
let currentPage='dashboard'

function nav(id,grupo){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'))
  document.querySelectorAll('.sb-item').forEach(i=>i.classList.remove('active'))
  const pg=document.getElementById('page-'+id)
  if(!pg) return
  pg.classList.add('active')
  // Ativar item no menu
  document.querySelectorAll('.sb-item').forEach(i=>{
    if(i.getAttribute('onclick')===`nav('${id}','${grupo}')`) i.classList.add('active')
  })
  const cfg=PAGES_CFG[id]||{title:id,path:'/'+id}
  document.getElementById('tb-title').textContent=cfg.title
  document.getElementById('tb-path').textContent=cfg.path
  currentPage=id
  if(cfg.load) cfg.load()
}

function toggleGroup(el,nome){
  el.classList.toggle('open')
  const sub=document.getElementById('grp-'+nome)
  if(sub) sub.classList.toggle('open')
  // Marcar grupo como ativo
  document.querySelectorAll('.sb-group-header').forEach(h=>h.classList.remove('active'))
  if(el.classList.contains('open')) el.classList.add('active')
}

// ═══════════════════════════════════════════════════
// WEBSOCKET
// ═══════════════════════════════════════════════════
let ws=null
function conectarWS(){
  const proto=location.protocol==='https:'?'wss':'ws'
  ws=new WebSocket(`${proto}://${location.host}/ws`)
  ws.onopen=()=>{
    document.getElementById('ws-dot').classList.add('connected')
  }
  ws.onmessage=(e)=>{
    const msg=JSON.parse(e.data)
    if(msg.tipo==='ping') ws.send('pong')
    else if(msg.tipo==='kpi_update') atualizarKPIs(msg.dados)
    else if(msg.tipo==='tv_popup') mostrarPopupTV(msg.dados)
    adicionarEvento(msg)
  }
  ws.onclose=()=>{
    document.getElementById('ws-dot').classList.remove('connected')
    setTimeout(conectarWS,5000) // reconectar
  }
}
conectarWS()

// ═══════════════════════════════════════════════════
// SYNC
// ═══════════════════════════════════════════════════
async function syncAgora(){
  const btn=document.querySelector('.btn-sync')
  btn.textContent='↻ Sincronizando...'
  btn.disabled=true
  await fetch('/api/sync',{method:'POST'}).catch(()=>{})
  setTimeout(()=>{
    btn.textContent='↻ Sync IXC'
    btn.disabled=false
    if(PAGES_CFG[currentPage]?.load) PAGES_CFG[currentPage].load()
  },1500)
}

// ═══════════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════════
async function loadDashboard(){
  try{
    const [resumo,alertas,top]=await Promise.all([
      apiFetch(`${SAIS}/visao-geral/resumo`),
      apiFetch(`${SAIS}/visao-geral/alertas?limit=5&apenas_nao_lidos=true`),
      apiFetch(`${SAIS}/produtividade/ranking`),
    ])
    renderDashboardKPIs(resumo)
    renderDashboardAlertas(alertas.alertas||[])
    renderDashboardCats(resumo.resumo)
    renderTopTecs(top.ranking||[])
    renderMeta(resumo)
    // Atualizar badge
    if(resumo.alertas_pendentes>0){
      const b=document.getElementById('badge-alertas')
      b.textContent=resumo.alertas_pendentes
      b.style.display='inline'
    }
  }catch(e){console.error('dashboard:',e)}
}

function renderDashboardKPIs(d){
  const r=d.resumo||{}
  const pct=d.meta_percentual||0
  document.getElementById('db-sub').textContent=
    `Atualizado às ${new Date().toLocaleTimeString('pt-BR')} · ${r.total||0} OS no período`
  document.getElementById('db-status-pill').textContent=
    pct>=80?'🟢 Meta ok':pct>=50?'🟡 Atenção':'🔴 Meta em risco'
  document.getElementById('db-kpis').innerHTML=`
    <div class="kpi" style="--ac:var(--cyan)" onclick="nav('ultimas-os','visao-geral')">
      <div class="kpi-lbl">Total OS</div><div class="kpi-val">${r.total||0}</div>
      <div class="kpi-sub">hoje</div>
    </div>
    <div class="kpi" style="--ac:var(--green)" onclick="abrirModalListaOS('finalizada')">
      <div class="kpi-lbl">Finalizadas</div><div class="kpi-val">${r.finalizadas||0}</div>
      <div class="kpi-sub">${pct}% da meta</div>
      <div class="kpi-badge ${pct>=80?'up':'dn'}">${pct}%</div>
    </div>
    <div class="kpi" style="--ac:var(--amber)" onclick="nav('os-atrasadas','central')">
      <div class="kpi-lbl">Em Campo</div><div class="kpi-val">${r.em_campo||0}</div>
      <div class="kpi-sub">em execução</div>
    </div>
    <div class="kpi" style="--ac:var(--cyan)" onclick="nav('agenda-dia','agenda')">
      <div class="kpi-lbl">Agendadas</div><div class="kpi-val">${r.agendadas||0}</div>
      <div class="kpi-sub">hoje</div>
    </div>
    <div class="kpi" style="--ac:var(--orange)" onclick="nav('ranking','produtividade')">
      <div class="kpi-lbl">Técnicos</div><div class="kpi-val">${d.tecnicos_ativos||0}</div>
      <div class="kpi-sub">ativos hoje</div>
    </div>
  `
}

function renderDashboardAlertas(alertas){
  const icons={critico:'🚨',aviso:'⚠️',info:'💬'}
  const cors={critico:'red',aviso:'amber',info:'green'}
  document.getElementById('db-alertas').innerHTML=alertas.slice(0,4).map(a=>`
    <div class="alert-chip ${cors[a.criticidade]||'amber'}" onclick="marcarAlertaLido(${a.id})">
      ${icons[a.criticidade]||'•'} ${a.titulo}
    </div>
  `).join('')||''
}

function renderDashboardCats(res){
  const cats=[
    {key:'servicos', label:'Serviço',  cor:'var(--cyan)'},
    {key:'suportes', label:'Suporte',  cor:'var(--amber)'},
    {key:'infra',    label:'Infra',    cor:'var(--purple)'},
    {key:'retiradas',label:'Retirada', cor:'var(--orange)'},
  ]
  const vals=cats.map(c=>res[c.key]||0)
  const maxV=Math.max(...vals,1)
  document.getElementById('db-cats').innerHTML=cats.map((c,i)=>`
    <div style="margin-bottom:10px;cursor:pointer" onclick="nav('prod-assunto','produtividade')">
      <div style="display:flex;justify-content:space-between;margin-bottom:3px">
        <span style="font-size:11px;font-weight:600">${c.label}</span>
        <span style="font-family:'DM Mono',monospace;font-size:11px;font-weight:700;color:${c.cor}">${vals[i]}</span>
      </div>
      <div class="bar-bg"><div class="bar-fill" style="width:${Math.round(vals[i]/maxV*100)}%;background:${c.cor}"></div></div>
    </div>
  `).join('')
}

function renderTopTecs(ranking){
  if(!ranking.length){
    document.getElementById('db-top-tecs').innerHTML=`<div class="empty"><div class="empty-icon">👥</div>Nenhum técnico hoje</div>`
    return
  }
  document.getElementById('db-top-tecs').innerHTML=ranking.slice(0,8).map((t,i)=>{
    const pct=t.pct_meta||0
    const cls=pct>=80?'green':pct>=50?'amber':'red'
    return `
      <div class="tec-row" onclick="abrirModalTecnico(${t.tecnico_id},'${esc(t.nome)}')">
        <span class="rpos ${rposCls(i)}">${i+1}</span>
        <div style="flex:1;font-size:12px;font-weight:600">${t.nome}</div>
        <div style="font-family:'DM Mono',monospace;font-size:11px;color:var(--cyan);font-weight:700;margin-right:8px">${t.total_os} OS</div>
        <span class="badge ${cls}">${pct}%</span>
      </div>
    `
  }).join('')
}

function renderMeta(d){
  const fins=d.resumo?.finalizadas||0
  const meta=d.meta_dia||150
  const pct=Math.min(d.meta_percentual||0,100)
  const cor=pct>=80?'var(--green)':pct>=50?'var(--amber)':'var(--red)'
  document.getElementById('db-meta').innerHTML=`
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:12px;text-align:center">
      <div><div style="font-size:18px;font-weight:800;font-family:'DM Mono',monospace;color:var(--cyan)">${fins}</div><div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em">Finalizadas</div></div>
      <div><div style="font-size:18px;font-weight:800;font-family:'DM Mono',monospace;color:var(--amber)">${Math.max(0,meta-fins)}</div><div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em">Restantes</div></div>
      <div><div style="font-size:18px;font-weight:800;font-family:'DM Mono',monospace;color:${cor}">${pct}%</div><div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em">Atingimento</div></div>
      <div><div style="font-size:18px;font-weight:800;font-family:'DM Mono',monospace;color:var(--orange)">${meta}</div><div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em">Meta</div></div>
    </div>
    <div class="meta-track"><div class="meta-fill" style="width:${pct}%;background:linear-gradient(90deg,var(--cyan),var(--green))"></div></div>
  `
}

// ═══════════════════════════════════════════════════
// EVENTOS
// ═══════════════════════════════════════════════════
const eventosBuffer=[]
function adicionarEvento(msg){
  if(msg.tipo==='ping'||msg.tipo==='connected') return
  eventosBuffer.unshift({...msg,recebido:new Date().toLocaleTimeString('pt-BR')})
  if(eventosBuffer.length>50) eventosBuffer.pop()
  if(currentPage==='eventos') renderEventos()
}
function loadEventos(){renderEventos()}
function renderEventos(){
  const el=document.getElementById('eventos-list')
  if(!eventosBuffer.length){el.innerHTML=`<div class="empty"><div class="empty-icon">📡</div>Aguardando eventos do WebSocket...</div>`;return}
  el.innerHTML=eventosBuffer.map(e=>`
    <div class="os-row" style="margin-bottom:6px">
      <div style="font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);margin-right:10px;flex-shrink:0">${e.recebido}</div>
      <div style="flex:1"><div style="font-size:11px;font-weight:600">${e.tipo}</div><div style="font-size:10px;color:var(--muted)">${JSON.stringify(e.dados||{}).slice(0,80)}</div></div>
    </div>
  `).join('')
}

// ═══════════════════════════════════════════════════
// ÚLTIMAS OS
// ═══════════════════════════════════════════════════
async function loadUltimasOS(){
  const d=await apiFetch(`${SAIS}/visao-geral/eventos-recentes?limit=30`)
  const el=document.getElementById('ultimas-os-list')
  if(!d.eventos?.length){el.innerHTML=`<div class="empty"><div class="empty-icon">📋</div>Nenhuma OS hoje</div>`;return}
  el.innerHTML=d.eventos.map(o=>`
    <div class="os-row" onclick="abrirModalOS(${o.ixc_os_id})">
      <div class="os-id">#${o.ixc_os_id}</div>
      <div class="os-info">
        <div class="os-assunto">${o.assunto||'—'}</div>
        <div class="os-meta"><span>${o.tecnico||'—'}</span><span>${fmtData(o.data_fechamento||o.data_abertura)}</span></div>
      </div>
      <span class="os-status-chip ${statusCls(o.status)}">${statusLabel(o.status)}</span>
    </div>
  `).join('')
}
function fmtData(d){if(!d)return'—';try{return new Date(d).toLocaleString('pt-BR',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'})}catch{return d}}

